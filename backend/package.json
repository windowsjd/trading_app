{
  "name": "trading-app",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:candles": "eslint --fix src/assets/asset-candles* src/assets/candle-* src/assets/market-candle* src/assets/live-candle* src/providers/kis/candles src/providers/binance/binance-candle* src/providers/binance/binance-kline* src/providers/binance/binance-live-candle* src/providers/binance/binance-public* src/realtime/live-candle-* scripts/candle-*.ts scripts/lib",
    "lint:candles:check": "eslint --no-fix --max-warnings=0 src/assets/asset-candles* src/assets/candle-* src/assets/market-candle* src/assets/live-candle* src/providers/kis/candles src/providers/binance/binance-candle* src/providers/binance/binance-kline* src/providers/binance/binance-live-candle* src/providers/binance/binance-public* src/realtime/live-candle-* scripts/candle-*.ts scripts/lib",
    "format:candles:check": "prettier --check src/assets/asset-candles* src/assets/candle-* src/assets/market-candle* src/assets/live-candle* src/providers/kis/candles src/providers/binance/binance-candle* src/providers/binance/binance-kline* src/providers/binance/binance-live-candle* src/providers/binance/binance-public* src/realtime/live-candle-* scripts/candle-*.ts scripts/lib",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "jest",
    "test:db:prepare": "prisma migrate deploy",
    "smoke:candle-fixture": "tsx scripts/candle-release-fixture-smoke.ts",
    "smoke:limit-order-candle-fixture": "tsx scripts/limit-order-candle-fixture-smoke.ts",
    "soak:limit-order-publisher-throughput": "tsx scripts/limit-order-phase3-integration.ts",
    "soak:limit-order-matcher-e2e": "tsx scripts/limit-order-matcher-e2e-integration.ts",
    "diagnose:limit-order-processed-events": "tsx scripts/limit-order-processed-event-capacity.ts",
    "integration:limit-order-legacy-deferred-migration": "tsx scripts/limit-order-legacy-deferred-migration-integration.ts",
    "integration:limit-order-idempotent-replay": "tsx scripts/limit-order-idempotent-replay-integration.ts",
    "smoke:candle-live": "tsx scripts/candle-live-smoke.ts",
    "smoke:candle-report": "tsx scripts/candle-live-smoke-report.ts",
    "dev:open-season": "tsx scripts/dev-open-season.ts",
    "dev:run-provider-ingestions": "tsx scripts/dev-run-provider-ingestions.ts",
    "dev:ensure-market-snapshots": "tsx scripts/dev-ensure-market-snapshots.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-ws": "^11.1.27",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.0",
    "ioredis": "^5.11.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "roots": [
      "<rootDir>",
      "<rootDir>/../scripts/lib"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
