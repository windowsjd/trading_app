NODE_ENV=development
PORT=3000
CORS_ORIGINS=

DATABASE_URL=postgresql://trading_app:trading_app_pw@localhost:5432/trading_app?schema=public
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=3000
REDIS_COMMAND_TIMEOUT_MS=1000

# Candle response cache (Redis). Disabled by default: the cache layer exists but
# is not yet wired into the candles endpoint, so enabling it has no effect on
# provider call volume in this step. A later serving step turns it on.
CANDLE_CACHE_ENABLED=false
CANDLE_CACHE_MAX_PAYLOAD_BYTES=2097152
CANDLE_CACHE_CURRENT_STALE_TTL_SECONDS=300
CANDLE_CACHE_HISTORICAL_FRESH_TTL_SECONDS=900
CANDLE_CACHE_HISTORICAL_STALE_TTL_SECONDS=3600
CANDLE_CACHE_EMPTY_FRESH_TTL_SECONDS=10
CANDLE_CACHE_EMPTY_STALE_TTL_SECONDS=60
CANDLE_SINGLE_FLIGHT_LOCK_TTL_MS=30000
CANDLE_SINGLE_FLIGHT_WAIT_TIMEOUT_MS=35000
CANDLE_SINGLE_FLIGHT_POLL_INTERVAL_MS=100
CANDLE_SINGLE_FLIGHT_RENEW_INTERVAL_MS=10000
CANDLE_SERVING_MODE=legacy
CANDLE_SERVING_CURRENT_DB_FRESHNESS_MS=60000
CANDLE_SERVING_ON_DEMAND_REFRESH_ENABLED=true
CANDLE_SERVING_ON_DEMAND_REFRESH_MAX_DURATION_MS=15000
CANDLE_SERVING_ON_DEMAND_REFRESH_MAX_PAGES=10
CANDLE_SERVING_ON_DEMAND_REFRESH_MAX_ROWS=5000
CANDLE_SERVING_STALE_WAITER_MAX_WAIT_MS=500
CANDLE_SERVING_ON_DEMAND_REPAIR_MAX_RANGE_MS=172800000
CANDLE_SERVING_DB_SMOKE=0

# Unit 3 live candle pipeline. Every gate is disabled by default. The KIS US
# stream is HDFSCNT0 delayed trade data and must remain explicitly opt-in.
CANDLE_LIVE_STREAMING_ENABLED=false
CANDLE_LIVE_KIS_ENABLED=false
CANDLE_LIVE_KIS_US_DELAYED_ENABLED=false
CANDLE_LIVE_BINANCE_ENABLED=false
CANDLE_LIVE_OWNER_LEASE_TTL_MS=30000
CANDLE_LIVE_OWNER_LEASE_RENEW_MS=10000
CANDLE_LIVE_RECONNECT_MIN_MS=1000
CANDLE_LIVE_RECONNECT_MAX_MS=30000
CANDLE_LIVE_FINALIZE_GRACE_MS=5000
CANDLE_LIVE_FINALIZER_INTERVAL_MS=1000
# Connection liveness (supervisor reconnect watchdog): close the provider
# socket only when NO frame of any kind (trade, ack, PINGPONG, WS ping)
# arrived within this window. Deliberately longer than trade staleness.
CANDLE_LIVE_CONNECTION_LIVENESS_TIMEOUT_MS=90000
# Trade freshness (readiness LIVE_PROVIDER_STALE): how old the last processed
# trade/kline event may be while the market can trade. Never closes sockets.
CANDLE_LIVE_TRADE_STALE_THRESHOLD_MS=30000
# DEPRECATED: CANDLE_LIVE_STALE_THRESHOLD_MS conflated the two settings above.
# It is only used as a fallback when a dedicated variable is unset; the
# dedicated variables always win. Invalid values still fail configuration.
# CANDLE_LIVE_STALE_THRESHOLD_MS=30000
CANDLE_LIVE_MAX_SUBSCRIPTIONS_PER_CLIENT=20
# Cap on ASSETS subscribed on one provider connection. Kept for backward
# compatibility and still enforced, but it is NOT the provider's real limit.
CANDLE_LIVE_MAX_PROVIDER_SUBSCRIPTIONS_PER_SHARD=200
# Cap on raw provider STREAMS on one connection — the unit Binance actually
# limits (1024 per connection). An asset costs ONE stream with the matcher off
# (`<symbol>@kline_5m`) and TWO with it on (`+ <symbol>@trade`, on the SAME
# socket), so an asset-count cap of 1024 would silently request 2048 streams
# and Binance would reject the whole SUBSCRIBE, leaving a connected socket that
# carries no market data at all. The effective asset budget is
# min(SUBSCRIPTIONS_PER_SHARD, floor(STREAMS_PER_SHARD / streams-per-asset)),
# assets beyond it are reported `capped` and fail limit-order readiness closed,
# and the actually-sent stream array is asserted against 1024 before SUBSCRIBE.
CANDLE_LIVE_MAX_PROVIDER_STREAMS_PER_SHARD=1024
CANDLE_LIVE_STATE_TTL_SECONDS=86400
CANDLE_LIVE_MAX_FUTURE_EVENT_SKEW_MS=10000
CANDLE_LIVE_WS_BACKPRESSURE_BYTES=1048576
# Old-generation / deferred bucket recovery (bounded queue, no SCAN).
CANDLE_LIVE_RECOVERY_MAX_BATCH=10
CANDLE_LIVE_RECOVERY_RETRY_MS=60000
# Live ingestion requires its reconciliation safety net. Production refuses
# to start with a live market enabled but its reconciliation disabled unless
# this explicit (exceptional, temporary) escape hatch is set.
LIVE_CANDLE_ALLOW_WITHOUT_RECONCILIATION=false

# REST canonical reconciliation. Market-specific flags also enable the Ops
# scheduler, but all defaults remain disabled.
CANDLE_RECONCILIATION_ENABLED=false
CANDLE_RECONCILIATION_KRX_ENABLED=false
CANDLE_RECONCILIATION_KRX_TIME=16:00
CANDLE_RECONCILIATION_KRX_GRACE_MINUTES=20
CANDLE_RECONCILIATION_US_ENABLED=false
CANDLE_RECONCILIATION_US_TIME=16:30
CANDLE_RECONCILIATION_US_GRACE_MINUTES=20
CANDLE_RECONCILIATION_CRYPTO_ENABLED=false
CANDLE_RECONCILIATION_CRYPTO_INTERVAL_SECONDS=300
CANDLE_RECONCILIATION_LOOKBACK_BUCKETS=24
CANDLE_RECONCILIATION_STARTUP_CATCH_UP_ENABLED=false
CANDLE_RECONCILIATION_MAX_CATCH_UP_HOURS=72
CANDLE_RECONCILIATION_MAX_ASSETS=200
CANDLE_RECONCILIATION_MAX_PAGES=10

# Versioned market calendar readiness coverage (defaults: current year
# through next year). Dates in years without a dataset are never assumed to
# be trading days; readiness reports MARKET_CALENDAR_COVERAGE_MISSING for
# missing years and MARKET_CALENDAR_PROVISIONAL for years whose dataset is
# not yet verified against the official exchange notice (e.g. KRX 2027 until
# the KRX year-end notice, expected ~Dec 2026, is published — then bump the
# dataset version and drop the -provisional suffix). If a 2026 release does
# not require 2027, set MARKET_CALENDAR_REQUIRED_THROUGH_YEAR=2026: this
# narrows the REQUIREMENT — never use env vars to present provisional data
# as audited.
# MARKET_CALENDAR_REQUIRED_FROM_YEAR=2026
# MARKET_CALENDAR_REQUIRED_THROUGH_YEAR=2027

# Fixture/live smokes are never enabled by the application itself.
CANDLE_LIVE_PIPELINE_SMOKE=0
CANDLE_LIVE_REDIS_SMOKE=0
# Release fixture smoke (real PostgreSQL+Redis, fixture providers only):
#   CANDLE_PIPELINE_RELEASE_FIXTURE_SMOKE=1 pnpm run smoke:candle-fixture
CANDLE_PIPELINE_RELEASE_FIXTURE_SMOKE=0
# Long real-provider smokes (scripts/candle-live-smoke.ts); see
# docs/candle-live-operations.md for the runbook.
CANDLE_LIVE_LONG_SMOKE=0
KIS_LIVE_CANDLE_SMOKE=0
BINANCE_LIVE_CANDLE_SMOKE=0
# Smoke commit traceability: every smoke artifact records gitCommit/gitBranch/
# gitDirty. A smoke aborts when no commit SHA can be resolved, and refuses a
# dirty working tree by default (dirty runs are never release validation).
# SMOKE_GIT_COMMIT=<full 40-char SHA override when git is unavailable>
# SMOKE_ALLOW_DIRTY=1   # development-only escape hatch; artifact keeps gitDirty=true

JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL=7d

PROVIDER_INGESTION_ENABLED=false
PROVIDER_INGESTION_MAX_SNAPSHOTS=500
PROVIDER_HTTP_TIMEOUT_MS=
PROVIDER_RAW_PAYLOAD_MAX_BYTES=

EXCHANGE_RATE_API_ENABLED=
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_BASE_URL=

KOREA_EXIM_EXCHANGE_ENABLED=false
KOREA_EXIM_EXCHANGE_AUTH_KEY=
KOREA_EXIM_EXCHANGE_BASE_URL=https://oapi.koreaexim.go.kr
KOREA_EXIM_EXCHANGE_DATA=AP01
KOREA_EXIM_EXCHANGE_LOOKBACK_DAYS=7

BINANCE_PUBLIC_MARKET_DATA_ENABLED=
BINANCE_REST_BASE_URL=
BINANCE_WS_MARKET_DATA_BASE_URL=
BINANCE_CRYPTO_SYMBOLS=
BINANCE_CRYPTO_USDT_AS_USD_EQUIVALENT=
BINANCE_WEBSOCKET_STREAMING_ENABLED=false
BINANCE_WEBSOCKET_STREAMING_RECONNECT_MIN_MS=1000
BINANCE_WEBSOCKET_STREAMING_RECONNECT_MAX_MS=30000
BINANCE_WEBSOCKET_STREAMING_HEARTBEAT_TIMEOUT_MS=60000
BINANCE_WS_SNAPSHOT_THROTTLE_MS=5000

KIS_MARKET_DATA_ENABLED=
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_REST_BASE_URL=
KIS_RATE_LIMIT_ENABLED=true
KIS_API_ENVIRONMENT=real
# Defaults: 125 for real, 1000 for virtual. OAuth is always at least 1000.
KIS_REST_MIN_INTERVAL_MS=125
KIS_OAUTH_MIN_INTERVAL_MS=1000
KIS_RATE_LIMIT_MAX_WAIT_MS=30000
KIS_RATE_LIMIT_MAX_QUEUE_SIZE=500
KIS_WS_BASE_URL=
KIS_MAX_WATCHLIST_SIZE=
KIS_DOMESTIC_SYMBOLS=
KIS_US_SYMBOLS=
KIS_WS_CUSTTYPE=
KIS_WS_DOMESTIC_TR_ID=
KIS_WS_OVERSEAS_DELAYED_TR_ID=
KIS_WS_SNAPSHOT_THROTTLE_MS=
KIS_WS_MAX_RUNTIME_MS=
KIS_WS_ALLOW_US_DELAYED=
KIS_WEBSOCKET_STREAMING_ENABLED=false
KIS_WEBSOCKET_STREAMING_RECONNECT_MIN_MS=1000
KIS_WEBSOCKET_STREAMING_RECONNECT_MAX_MS=30000
KIS_WEBSOCKET_STREAMING_HEARTBEAT_TIMEOUT_MS=60000
KIS_PRICE_INGESTION_MODE=websocket_trade

ENABLE_PROVIDER_LIVE_SMOKE=
KIS_DOMESTIC_CANDLE_LIVE_SMOKE=0
KIS_DOMESTIC_CANDLE_SMOKE_SYMBOL=005930
KIS_DOMESTIC_CANDLE_SMOKE_MARKET=J
KIS_US_CANDLE_LIVE_SMOKE=0
KIS_US_CANDLE_SMOKE_SYMBOL=AAPL
KIS_US_CANDLE_SMOKE_MARKET=NAS
# Opt-in candle sync smokes: DB fixture smoke (needs PostgreSQL + Redis) and
# small bounded live-provider smokes. Never enabled by default.
MARKET_CANDLE_SYNC_DB_SMOKE=0
KIS_PERIOD_CANDLE_LIVE_SMOKE=0
BINANCE_CANDLE_LIVE_SMOKE=0
BINANCE_CANDLE_SMOKE_SYMBOL=BTCUSDT

# Checkpointed market candle sync (manual Ops job market_candle_sync; no
# scheduler in this phase). Budgets are per asset/feed run; the lock renewal
# interval must stay below the lock TTL. KIS-backed assets always sync one at
# a time regardless of MARKET_CANDLE_SYNC_ASSET_CONCURRENCY (which bounds
# crypto fan-out and is capped at 8).
MARKET_CANDLE_SYNC_MAX_PAGES=300
MARKET_CANDLE_SYNC_MAX_ROWS=50000
MARKET_CANDLE_SYNC_MAX_DURATION_MS=180000
MARKET_CANDLE_SYNC_ASSET_CONCURRENCY=2
MARKET_CANDLE_SYNC_INCREMENTAL_OVERLAP_MINUTES=120
MARKET_CANDLE_SYNC_LOCK_TTL_SECONDS=120
MARKET_CANDLE_SYNC_LOCK_RENEW_SECONDS=40

SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_PROVIDER_FX_ENABLED=false
SCHEDULER_PROVIDER_BINANCE_ENABLED=false
SCHEDULER_PROVIDER_KIS_ENABLED=false
SCHEDULER_DAILY_SNAPSHOT_ENABLED=false
SCHEDULER_RANKING_ENABLED=false
SCHEDULER_SEASON_LIFECYCLE_ENABLED=false
SCHEDULER_SETTLEMENT_ENABLED=false
SCHEDULER_REWARD_MARKER_ENABLED=false
SCHEDULER_MARKET_CANDLE_RETENTION_ENABLED=false
MARKET_CANDLE_5M_RETENTION_DAYS=35
MARKET_CANDLE_RETENTION_BATCH_SIZE=5000
SCHEDULER_MARKET_CANDLE_RETENTION_HOUR=4
SCHEDULER_MARKET_CANDLE_RETENTION_MINUTE=0
SCHEDULER_MARKET_CANDLE_RETENTION_RUN_ON_STARTUP=false
SCHEDULER_TICK_INTERVAL_MS=60000
SCHEDULER_PROVIDER_FX_INTERVAL_SECONDS=3600
SCHEDULER_PROVIDER_BINANCE_INTERVAL_SECONDS=60
SCHEDULER_PROVIDER_KIS_INTERVAL_SECONDS=60
SCHEDULER_PROVIDER_INGESTION_RUN_ON_STARTUP=false
SCHEDULER_PROVIDER_KIS_MAX_SNAPSHOTS=500
SCHEDULER_LOCK_TTL_SECONDS=600
SCHEDULER_MAX_ATTEMPTS=1

# Production ranking scheduler example.
# Defaults above stay disabled; copy these non-secret values to the deployment env
# only when automatic current ranking refresh and scheduled equity snapshots are intended.
# SCHEDULER_ENABLED=true
# SCHEDULER_RANKING_ENABLED=true
# SCHEDULER_TICK_INTERVAL_MS=60000
# SCHEDULER_LOCK_TTL_SECONDS=600
# SCHEDULER_MAX_ATTEMPTS=1
#
# Minimal alternative accepted by the backend:
# ENABLE_RANKING_SCHEDULER=true
#
# Provider ingestion and reward marker scheduler flags are separate gates.

ENABLE_RANKING_SCHEDULER=false
ENABLE_PROVIDER_KIS_SCHEDULER=false
RANKING_REFRESH_INTERVAL_SECONDS=60
ENABLE_SEASON_LIFECYCLE_SCHEDULER=false
ENABLE_SEASON_SETTLEMENT_SCHEDULER=false
SEASON_SETTLEMENT_INTERVAL_SECONDS=60

# Limit-buy registration gate. Default false. Enabled users can register
# GTC-style limit buys that reserve cash. Automatic path-A matching has the
# separate flag below. Cancel and lifecycle cleanup work while either flag is
# false.
#
# STRICTLY VALIDATED AT STARTUP. Accepted values are exactly true / false /
# 1 / 0, trimmed and case-insensitive (TRUE and False are fine). Omitting the
# variable entirely means false. ANY other value — yes, enabled, tru, or an
# explicitly empty value — aborts bootstrap with an "Invalid environment
# configuration" error instead of being silently read as off, because a flag
# an operator believes is on but is quietly off is the dangerous failure.
LIMIT_ORDER_ENABLED=false

# Phase 2 path A: normalized KIS/Binance live trade -> Redis Stream -> one
# PostgreSQL-advisory-lock leader -> full-fill limit-buy execution. Default is
# false. When true, a stale/unavailable matcher blocks only new limit quotes
# and creates; cancel, lifecycle cleanup, market orders, and FX remain usable.
# The existing provider WebSocket for the requested asset must also be enabled
# and connected; a separate live-candle connection is not a matching fallback.
LIMIT_ORDER_AUTO_EXECUTION_ENABLED=false
LIMIT_ORDER_EVENT_STREAM_KEY=limit-order:price-events:v1
LIMIT_ORDER_EVENT_CONSUMER_GROUP=limit-order-matchers:v1
LIMIT_ORDER_EVENT_BLOCK_MS=3000
LIMIT_ORDER_EVENT_READ_BATCH_SIZE=100
LIMIT_ORDER_CANDIDATE_BATCH_SIZE=100
LIMIT_ORDER_EVENT_MAXLEN=100000
LIMIT_ORDER_PENDING_IDLE_MS=30000
LIMIT_ORDER_RECLAIM_INTERVAL_MS=30000
LIMIT_ORDER_MATCHER_HEARTBEAT_INTERVAL_MS=5000
LIMIT_ORDER_MATCHER_HEALTH_MAX_AGE_MS=15000

# Phase 3 matcher backlog health gate. These block ONLY new limit
# quote/create; cancel, lifecycle cleanup, market orders and FX stay usable.
# A quiet market never trips them: ACK staleness is judged only when a
# backlog actually exists, and before a new leader's first ACK the reference
# point is when that leader took over.
LIMIT_ORDER_MATCHER_MAX_LAG=5000
LIMIT_ORDER_MATCHER_MAX_PENDING=1000
LIMIT_ORDER_MATCHER_MAX_ACK_AGE_MS=60000
LIMIT_ORDER_MATCHER_MAX_OLDEST_PENDING_AGE_MS=60000
# Minimum fraction of LIMIT_ORDER_EVENT_MAXLEN that must stay free. A stream
# sitting at its cap silently trims entries a consumer has not read yet.
# Must be in [0, 1).
LIMIT_ORDER_EVENT_RETENTION_HEADROOM_RATIO=0.2

# How stale the canonical provider connection's last frame may be before the
# requested asset is treated as not ready for automatic matching.
LIMIT_ORDER_PROVIDER_LIVENESS_MAX_AGE_MS=60000
# How long the per-asset readiness PROOF a limit create carries stays usable.
#
# A create resolves readiness BEFORE its transaction (where a Redis round trip
# to the shared view is allowed) and re-verifies it INSIDE the transaction
# (where one is not, because the event-boundary advisory lock is held). This
# bounds the gap between the two, so it must comfortably cover a create's row
# lock waits. Must not exceed LIMIT_ORDER_PROVIDER_LIVENESS_MAX_AGE_MS: a proof
# may never outlive the connection evidence it was based on.
LIMIT_ORDER_PROVIDER_READINESS_PROOF_MAX_AGE_MS=15000

# Poller-side asset metadata cache. Routing/validation only — the candidate
# query and the execution transaction always re-verify the asset, so a stale
# entry can never authorize a fill.
LIMIT_ORDER_ASSET_CACHE_TTL_MS=5000
LIMIT_ORDER_ASSET_CACHE_MAX_ENTRIES=2000

# Phase 3 path B: confirmed 5-minute candle safety net for limit buys whose
# live trade event never reached the Redis Stream. It fills at the ORDER'S
# LIMIT PRICE — never at the candle low, which is only evidence that the limit
# was touched — and never uses the partially elapsed candle an order was
# submitted into.
#
# Path B REQUIRES path A: setting this true while
# LIMIT_ORDER_AUTO_EXECUTION_ENABLED is false ABORTS STARTUP rather than
# silently downgrading every fill to a delayed limit-price fill.
#
# Runs as the Ops job `limit_order_candle_reconciliation` on the ordinary 60s
# scheduler tick, serialized by the PostgreSQL OpsJobLock.
LIMIT_ORDER_CANDLE_RECONCILIATION_ENABLED=false
# CATCH-UP / WARNING BOUND ONLY — never a correctness bound. The sweep's scan
# position is the DURABLE watermark in limit_order_reconciliation_checkpoints,
# not `now - lookback`: an unprocessed candle older than this is carried by the
# checkpoint and the deferred queue, never dropped. This value only decides how
# much first-run catch-up is worth an operational warning.
LIMIT_ORDER_CANDLE_RECONCILIATION_LOOKBACK_MS=3600000
LIMIT_ORDER_CANDLE_RECONCILIATION_CANDLE_BATCH_SIZE=200
LIMIT_ORDER_CANDLE_RECONCILIATION_ORDER_BATCH_SIZE=100
# How long a closed window must have elapsed before the watermark may advance
# past it. The finalizer writes a canonical closed row some time after the
# window ends; stepping the position over a window whose row has not landed yet
# would skip it forever. Recent candles are still PROCESSED immediately — only
# the position lags. Must be <= LIMIT_ORDER_CANDLE_RECONCILIATION_LOOKBACK_MS.
LIMIT_ORDER_CANDLE_RECONCILIATION_WATERMARK_SAFETY_LAG_MS=900000
# Window COMPLETION protocol (per-asset finalization cursor). ingest_seq can
# only order candle rows that EXIST; the completion cursor accounts for
# windows whose row is ABSENT, telling provider-confirmed no-trade apart from
# a feed/finalizer failure. Per sweep it evaluates up to WINDOW_BATCH_SIZE
# windows per asset and spends up to REPAIR_BUDGET REST-repair probes overall.
LIMIT_ORDER_CANDLE_COMPLETION_WINDOW_BATCH_SIZE=24
LIMIT_ORDER_CANDLE_COMPLETION_REPAIR_BUDGET_PER_SWEEP=5
# Asset-scoped health gate: how long an asset's FIRST unaccounted window may
# stay pending before that asset's new limit quotes/creates fail closed with
# LIMIT_ORDER_CANDLE_FINALIZER_STALE, and how many deferred candles one asset
# may accumulate before LIMIT_ORDER_CANDLE_ASSET_BACKLOG_EXCEEDED. Both gate
# ONLY the named asset; other assets, cancel, cleanup, market orders and FX
# keep working.
LIMIT_ORDER_CANDLE_ASSET_FINALIZER_STALE_MS=1800000
LIMIT_ORDER_CANDLE_MAX_ASSET_DEFERRED_BACKLOG=10
# Two-phase guard on the STORAGE-order scan position
# (market_candles.ingest_seq). A sequence value is assigned when a candle row is
# INSERTED but only becomes visible when its transaction COMMITS, so the highest
# visible value can still have uncommitted holes below it. A run may therefore
# only advance onto a value an EARLIER run observed, and only once this much
# database time has passed since that observation.
#
# It is not the only bound: when the database role can read other backends'
# xact_start (it can when the application uses one role, which is the normal
# case), an in-flight write transaction older than the observation holds the
# position back exactly, regardless of this value. Raise it only if candle
# writes can legitimately sit in transactions longer than this.
LIMIT_ORDER_CANDLE_RECONCILIATION_INGEST_SETTLE_GRACE_MS=60000
# Durable deferred-candle retry queue. A candle that fails is enqueued BEFORE
# the watermark passes it, so one bad asset delays one candle instead of
# blocking every later candle behind it.
LIMIT_ORDER_CANDLE_RECONCILIATION_DEFERRED_RETRY_BATCH_SIZE=50
LIMIT_ORDER_CANDLE_RECONCILIATION_DEFERRED_RETRY_BASE_DELAY_MS=60000
LIMIT_ORDER_CANDLE_RECONCILIATION_DEFERRED_RETRY_MAX_DELAY_MS=1800000
LIMIT_ORDER_CANDLE_RECONCILIATION_DEFERRED_MAX_ATTEMPTS=50
# Path-B health gate for NEW limit quotes/creates ONLY. It never blocks cancel,
# season-end / exclusion cleanup, market orders, or FX. Its error codes are
# distinct from the path-A matcher gate:
#   LIMIT_ORDER_CANDLE_RECONCILIATION_UNAVAILABLE
#   LIMIT_ORDER_CANDLE_RECONCILIATION_STALE
#   LIMIT_ORDER_CANDLE_RECONCILIATION_BACKLOG_EXCEEDED
#   LIMIT_ORDER_CANDLE_RECONCILIATION_GAP_DETECTED
#   LIMIT_ORDER_CANDLE_RESERVATION_MISMATCH
LIMIT_ORDER_CANDLE_RECONCILIATION_HEALTH_MAX_AGE_MS=300000
LIMIT_ORDER_CANDLE_RECONCILIATION_MAX_DEFERRED_BACKLOG=50
LIMIT_ORDER_CANDLE_RECONCILIATION_MAX_DEFERRED_AGE_MS=3600000
LIMIT_ORDER_CANDLE_RECONCILIATION_MAX_RESERVATION_MISMATCH=1

# Cross-instance provider trade readiness (DEFAULT OFF).
#
# ProviderTradeRouteRegistry is per-process memory that mirrors the socket THIS
# process owns. In a multi-instance deployment the live-candle supervisor owns
# the Binance/KIS connection on ONE instance while HTTP requests land on any of
# them, so without this the same limit quote/create succeeds on the owner and
# fails with LIMIT_ORDER_PROVIDER_UNAVAILABLE on every other pod.
#
# The owner publishes routing/liveness metadata to Redis and every other
# instance reads it. Only routing metadata is published — never a credential,
# an approval key, an access token, or a raw provider frame. Every failure mode
# (Redis down, missing meta, expired TTL, stale frame, superseded generation)
# resolves to NOT ready; there is no fail-open path.
#
# Requires LIMIT_ORDER_AUTO_EXECUTION_ENABLED=true and REDIS_URL, and the
# LIVE-CANDLE SUPERVISOR as the socket owner: publishing rights are exchanged
# for the supervisor's Redis owner lease (candles:live:v1:owner:<provider>:0)
# and re-verified inside Redis on every write. A legacy-streaming owner has no
# lease and cannot publish — non-owner instances then fail closed by design.
# The TTL is the owner heartbeat and must exceed twice the publish interval.
LIMIT_ORDER_SHARED_READINESS_ENABLED=false
LIMIT_ORDER_SHARED_READINESS_TTL_SECONDS=30
LIMIT_ORDER_SHARED_READINESS_PUBLISH_INTERVAL_MS=5000
# Optional stable identity for compare-and-swap ownership. Defaults to
# host:pid:uuid, which is correct unless you need a stable identity across
# restarts (a StatefulSet pod name, for example).
# LIMIT_ORDER_SHARED_READINESS_INSTANCE_ID=

# Durable dedupe table (limit_order_processed_events) growth observation.
#
# NO retention deletion is performed: a deleted event id could be re-delivered
# and fill a LATER order, and provider trade-id reuse cannot be ruled out. See
# docs/limit-order-live-matching-operations.md for the capacity model and the
# partition plan. The matcher therefore only OBSERVES growth, and it does so
# with APPROXIMATE aggregates on a multi-minute cadence: the previous per-60s
# exact COUNT(*) over an unbounded append-only table cost the matcher's own
# event loop more every day it ran.
# Exact figures on demand: `pnpm run diagnose:limit-order-processed-events`.
LIMIT_ORDER_PROCESSED_EVENT_STATS_INTERVAL_MS=300000
LIMIT_ORDER_PROCESSED_EVENT_WARN_BYTES=10737418240
LIMIT_ORDER_PROCESSED_EVENT_WARN_ROW_COUNT=500000000

# Opt-in switch for the limit-order PostgreSQL integration suites
# (reservation atomicity + create-vs-exclusion / create-vs-season-end races).
# Unset, those specs skip so `pnpm test` needs no database. Set to 1 with a
# migrated DATABASE_URL to run them:
#   LIMIT_ORDER_RESERVATION_DB_INTEGRATION=1 pnpm exec jest src/orders/limit-order-create-race.integration.spec.ts
# LIMIT_ORDER_RESERVATION_DB_INTEGRATION=1
# LIMIT_ORDER_AUTO_EXECUTION_INTEGRATION=1
# Phase 3 suite (event-boundary mutex, path B, A/B races, health gate,
# throughput sweep). Needs a migrated DATABASE_URL and a live REDIS_URL:
#   LIMIT_ORDER_PHASE3_INTEGRATION=1 pnpm exec jest src/orders/limit-order-phase3.integration.spec.ts
# The standalone PUBLISHER throughput/soak run is
# `pnpm run soak:limit-order-publisher-throughput` (XADD only).
# LIMIT_ORDER_PHASE3_INTEGRATION=1
#
# Event-boundary concurrency suite: two concurrent acquireSession() calls on ONE
# service instance must serialize on a real PostgreSQL advisory lock and leave
# no residual lock. Needs a migrated DATABASE_URL:
#   LIMIT_ORDER_BOUNDARY_CONCURRENCY_INTEGRATION=1 pnpm exec jest src/orders/limit-matching/limit-order-boundary-concurrency.integration.spec.ts
# LIMIT_ORDER_BOUNDARY_CONCURRENCY_INTEGRATION=1
#
# Path-B durable checkpoint suite: proves a candle unprocessed for longer than
# the lookback is still processed, that a restart resumes from the checkpoint,
# and that a retention gap is detected and fails new orders closed. Needs a
# DISPOSABLE migrated DATABASE_URL (it resets the 5m checkpoint row):
#   LIMIT_ORDER_CANDLE_CHECKPOINT_INTEGRATION=1 pnpm exec jest src/orders/limit-matching/limit-order-candle-checkpoint.integration.spec.ts
# LIMIT_ORDER_CANDLE_CHECKPOINT_INTEGRATION=1
#
# Multi-instance shared readiness suite: two independent registry/service
# instances against one real Redis. Needs a live REDIS_URL:
#   LIMIT_ORDER_SHARED_READINESS_INTEGRATION=1 pnpm exec jest src/providers/provider-trade-readiness.integration.spec.ts
# LIMIT_ORDER_SHARED_READINESS_INTEGRATION=1
#
# END-TO-END matcher suite (XADD -> XACK). This is NOT the publisher number:
# the consumer additionally reads the group, validates, takes the boundary,
# dedupes, queries candidates, runs an execution transaction, inserts the
# processed-event row and ACKs, so its rate is far lower. CI asserts only
# hardware-independent invariants; the standalone soak run that PRINTS rates is
# `pnpm run soak:limit-order-matcher-e2e`. Needs a DISPOSABLE migrated
# DATABASE_URL and a live REDIS_URL:
#   LIMIT_ORDER_MATCHER_E2E_INTEGRATION=1 pnpm exec jest src/orders/limit-matching/limit-order-matcher-e2e.integration.spec.ts
# LIMIT_ORDER_MATCHER_E2E_INTEGRATION=1
