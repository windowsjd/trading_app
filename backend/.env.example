NODE_ENV=development
PORT=3000
CORS_ORIGINS=

DATABASE_URL=postgresql://trading_app:trading_app_pw@localhost:5432/trading_app?schema=public
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=3000
REDIS_COMMAND_TIMEOUT_MS=1000

# Candle response cache (Redis). Disabled by default: the cache layer exists but
# is not yet wired into the candles endpoint, so enabling it has no effect on
# provider call volume in this step. A later serving step turns it on.
CANDLE_CACHE_ENABLED=false
CANDLE_CACHE_MAX_PAYLOAD_BYTES=2097152
CANDLE_CACHE_CURRENT_STALE_TTL_SECONDS=300
CANDLE_CACHE_HISTORICAL_FRESH_TTL_SECONDS=900
CANDLE_CACHE_HISTORICAL_STALE_TTL_SECONDS=3600
CANDLE_CACHE_EMPTY_FRESH_TTL_SECONDS=10
CANDLE_CACHE_EMPTY_STALE_TTL_SECONDS=60
CANDLE_SINGLE_FLIGHT_LOCK_TTL_MS=30000
CANDLE_SINGLE_FLIGHT_WAIT_TIMEOUT_MS=35000
CANDLE_SINGLE_FLIGHT_POLL_INTERVAL_MS=100
CANDLE_SINGLE_FLIGHT_RENEW_INTERVAL_MS=10000
CANDLE_SERVING_MODE=legacy
CANDLE_SERVING_CURRENT_DB_FRESHNESS_MS=60000
CANDLE_SERVING_ON_DEMAND_REFRESH_ENABLED=true
CANDLE_SERVING_ON_DEMAND_REFRESH_MAX_DURATION_MS=15000
CANDLE_SERVING_ON_DEMAND_REFRESH_MAX_PAGES=10
CANDLE_SERVING_ON_DEMAND_REFRESH_MAX_ROWS=5000
CANDLE_SERVING_STALE_WAITER_MAX_WAIT_MS=500
CANDLE_SERVING_ON_DEMAND_REPAIR_MAX_RANGE_MS=172800000
CANDLE_SERVING_DB_SMOKE=0

# Unit 3 live candle pipeline. Every gate is disabled by default. The KIS US
# stream is HDFSCNT0 delayed trade data and must remain explicitly opt-in.
CANDLE_LIVE_STREAMING_ENABLED=false
CANDLE_LIVE_KIS_ENABLED=false
CANDLE_LIVE_KIS_US_DELAYED_ENABLED=false
CANDLE_LIVE_BINANCE_ENABLED=false
CANDLE_LIVE_OWNER_LEASE_TTL_MS=30000
CANDLE_LIVE_OWNER_LEASE_RENEW_MS=10000
CANDLE_LIVE_RECONNECT_MIN_MS=1000
CANDLE_LIVE_RECONNECT_MAX_MS=30000
CANDLE_LIVE_FINALIZE_GRACE_MS=5000
CANDLE_LIVE_FINALIZER_INTERVAL_MS=1000
# Connection liveness (supervisor reconnect watchdog): close the provider
# socket only when NO frame of any kind (trade, ack, PINGPONG, WS ping)
# arrived within this window. Deliberately longer than trade staleness.
CANDLE_LIVE_CONNECTION_LIVENESS_TIMEOUT_MS=90000
# Trade freshness (readiness LIVE_PROVIDER_STALE): how old the last processed
# trade/kline event may be while the market can trade. Never closes sockets.
CANDLE_LIVE_TRADE_STALE_THRESHOLD_MS=30000
# DEPRECATED: CANDLE_LIVE_STALE_THRESHOLD_MS conflated the two settings above.
# It is only used as a fallback when a dedicated variable is unset; the
# dedicated variables always win. Invalid values still fail configuration.
# CANDLE_LIVE_STALE_THRESHOLD_MS=30000
CANDLE_LIVE_MAX_SUBSCRIPTIONS_PER_CLIENT=20
CANDLE_LIVE_MAX_PROVIDER_SUBSCRIPTIONS_PER_SHARD=200
CANDLE_LIVE_STATE_TTL_SECONDS=86400
CANDLE_LIVE_MAX_FUTURE_EVENT_SKEW_MS=10000
CANDLE_LIVE_WS_BACKPRESSURE_BYTES=1048576
# Old-generation / deferred bucket recovery (bounded queue, no SCAN).
CANDLE_LIVE_RECOVERY_MAX_BATCH=10
CANDLE_LIVE_RECOVERY_RETRY_MS=60000
# Live ingestion requires its reconciliation safety net. Production refuses
# to start with a live market enabled but its reconciliation disabled unless
# this explicit (exceptional, temporary) escape hatch is set.
LIVE_CANDLE_ALLOW_WITHOUT_RECONCILIATION=false

# REST canonical reconciliation. Market-specific flags also enable the Ops
# scheduler, but all defaults remain disabled.
CANDLE_RECONCILIATION_ENABLED=false
CANDLE_RECONCILIATION_KRX_ENABLED=false
CANDLE_RECONCILIATION_KRX_TIME=16:00
CANDLE_RECONCILIATION_KRX_GRACE_MINUTES=20
CANDLE_RECONCILIATION_US_ENABLED=false
CANDLE_RECONCILIATION_US_TIME=16:30
CANDLE_RECONCILIATION_US_GRACE_MINUTES=20
CANDLE_RECONCILIATION_CRYPTO_ENABLED=false
CANDLE_RECONCILIATION_CRYPTO_INTERVAL_SECONDS=300
CANDLE_RECONCILIATION_LOOKBACK_BUCKETS=24
CANDLE_RECONCILIATION_STARTUP_CATCH_UP_ENABLED=false
CANDLE_RECONCILIATION_MAX_CATCH_UP_HOURS=72
CANDLE_RECONCILIATION_MAX_ASSETS=200
CANDLE_RECONCILIATION_MAX_PAGES=10

# Versioned market calendar readiness coverage (defaults: current year
# through next year). Dates in years without a dataset are never assumed to
# be trading days; readiness reports MARKET_CALENDAR_COVERAGE_MISSING for
# missing years and MARKET_CALENDAR_PROVISIONAL for years whose dataset is
# not yet verified against the official exchange notice (e.g. KRX 2027 until
# the KRX year-end notice, expected ~Dec 2026, is published — then bump the
# dataset version and drop the -provisional suffix). If a 2026 release does
# not require 2027, set MARKET_CALENDAR_REQUIRED_THROUGH_YEAR=2026: this
# narrows the REQUIREMENT — never use env vars to present provisional data
# as audited.
# MARKET_CALENDAR_REQUIRED_FROM_YEAR=2026
# MARKET_CALENDAR_REQUIRED_THROUGH_YEAR=2027

# Fixture/live smokes are never enabled by the application itself.
CANDLE_LIVE_PIPELINE_SMOKE=0
CANDLE_LIVE_REDIS_SMOKE=0
# Release fixture smoke (real PostgreSQL+Redis, fixture providers only):
#   CANDLE_PIPELINE_RELEASE_FIXTURE_SMOKE=1 pnpm run smoke:candle-fixture
CANDLE_PIPELINE_RELEASE_FIXTURE_SMOKE=0
# Long real-provider smokes (scripts/candle-live-smoke.ts); see
# docs/candle-live-operations.md for the runbook.
CANDLE_LIVE_LONG_SMOKE=0
KIS_LIVE_CANDLE_SMOKE=0
BINANCE_LIVE_CANDLE_SMOKE=0
# Smoke commit traceability: every smoke artifact records gitCommit/gitBranch/
# gitDirty. A smoke aborts when no commit SHA can be resolved, and refuses a
# dirty working tree by default (dirty runs are never release validation).
# SMOKE_GIT_COMMIT=<full 40-char SHA override when git is unavailable>
# SMOKE_ALLOW_DIRTY=1   # development-only escape hatch; artifact keeps gitDirty=true

JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL=7d

PROVIDER_INGESTION_ENABLED=false
PROVIDER_INGESTION_MAX_SNAPSHOTS=500
PROVIDER_HTTP_TIMEOUT_MS=
PROVIDER_RAW_PAYLOAD_MAX_BYTES=

EXCHANGE_RATE_API_ENABLED=
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_BASE_URL=

KOREA_EXIM_EXCHANGE_ENABLED=false
KOREA_EXIM_EXCHANGE_AUTH_KEY=
KOREA_EXIM_EXCHANGE_BASE_URL=https://oapi.koreaexim.go.kr
KOREA_EXIM_EXCHANGE_DATA=AP01
KOREA_EXIM_EXCHANGE_LOOKBACK_DAYS=7

BINANCE_PUBLIC_MARKET_DATA_ENABLED=
BINANCE_REST_BASE_URL=
BINANCE_WS_MARKET_DATA_BASE_URL=
BINANCE_CRYPTO_SYMBOLS=
BINANCE_CRYPTO_USDT_AS_USD_EQUIVALENT=
BINANCE_WEBSOCKET_STREAMING_ENABLED=false
BINANCE_WEBSOCKET_STREAMING_RECONNECT_MIN_MS=1000
BINANCE_WEBSOCKET_STREAMING_RECONNECT_MAX_MS=30000
BINANCE_WEBSOCKET_STREAMING_HEARTBEAT_TIMEOUT_MS=60000
BINANCE_WS_SNAPSHOT_THROTTLE_MS=5000

KIS_MARKET_DATA_ENABLED=
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_REST_BASE_URL=
KIS_RATE_LIMIT_ENABLED=true
KIS_API_ENVIRONMENT=real
# Defaults: 125 for real, 1000 for virtual. OAuth is always at least 1000.
KIS_REST_MIN_INTERVAL_MS=125
KIS_OAUTH_MIN_INTERVAL_MS=1000
KIS_RATE_LIMIT_MAX_WAIT_MS=30000
KIS_RATE_LIMIT_MAX_QUEUE_SIZE=500
KIS_WS_BASE_URL=
KIS_MAX_WATCHLIST_SIZE=
KIS_DOMESTIC_SYMBOLS=
KIS_US_SYMBOLS=
KIS_WS_CUSTTYPE=
KIS_WS_DOMESTIC_TR_ID=
KIS_WS_OVERSEAS_DELAYED_TR_ID=
KIS_WS_SNAPSHOT_THROTTLE_MS=
KIS_WS_MAX_RUNTIME_MS=
KIS_WS_ALLOW_US_DELAYED=
KIS_WEBSOCKET_STREAMING_ENABLED=false
KIS_WEBSOCKET_STREAMING_RECONNECT_MIN_MS=1000
KIS_WEBSOCKET_STREAMING_RECONNECT_MAX_MS=30000
KIS_WEBSOCKET_STREAMING_HEARTBEAT_TIMEOUT_MS=60000
KIS_PRICE_INGESTION_MODE=websocket_trade

ENABLE_PROVIDER_LIVE_SMOKE=
KIS_DOMESTIC_CANDLE_LIVE_SMOKE=0
KIS_DOMESTIC_CANDLE_SMOKE_SYMBOL=005930
KIS_DOMESTIC_CANDLE_SMOKE_MARKET=J
KIS_US_CANDLE_LIVE_SMOKE=0
KIS_US_CANDLE_SMOKE_SYMBOL=AAPL
KIS_US_CANDLE_SMOKE_MARKET=NAS
# Opt-in candle sync smokes: DB fixture smoke (needs PostgreSQL + Redis) and
# small bounded live-provider smokes. Never enabled by default.
MARKET_CANDLE_SYNC_DB_SMOKE=0
KIS_PERIOD_CANDLE_LIVE_SMOKE=0
BINANCE_CANDLE_LIVE_SMOKE=0
BINANCE_CANDLE_SMOKE_SYMBOL=BTCUSDT

# Checkpointed market candle sync (manual Ops job market_candle_sync; no
# scheduler in this phase). Budgets are per asset/feed run; the lock renewal
# interval must stay below the lock TTL. KIS-backed assets always sync one at
# a time regardless of MARKET_CANDLE_SYNC_ASSET_CONCURRENCY (which bounds
# crypto fan-out and is capped at 8).
MARKET_CANDLE_SYNC_MAX_PAGES=300
MARKET_CANDLE_SYNC_MAX_ROWS=50000
MARKET_CANDLE_SYNC_MAX_DURATION_MS=180000
MARKET_CANDLE_SYNC_ASSET_CONCURRENCY=2
MARKET_CANDLE_SYNC_INCREMENTAL_OVERLAP_MINUTES=120
MARKET_CANDLE_SYNC_LOCK_TTL_SECONDS=120
MARKET_CANDLE_SYNC_LOCK_RENEW_SECONDS=40

SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_PROVIDER_FX_ENABLED=false
SCHEDULER_PROVIDER_BINANCE_ENABLED=false
SCHEDULER_PROVIDER_KIS_ENABLED=false
SCHEDULER_DAILY_SNAPSHOT_ENABLED=false
SCHEDULER_RANKING_ENABLED=false
SCHEDULER_SEASON_LIFECYCLE_ENABLED=false
SCHEDULER_SETTLEMENT_ENABLED=false
SCHEDULER_REWARD_MARKER_ENABLED=false
SCHEDULER_MARKET_CANDLE_RETENTION_ENABLED=false
MARKET_CANDLE_5M_RETENTION_DAYS=35
MARKET_CANDLE_RETENTION_BATCH_SIZE=5000
SCHEDULER_MARKET_CANDLE_RETENTION_HOUR=4
SCHEDULER_MARKET_CANDLE_RETENTION_MINUTE=0
SCHEDULER_MARKET_CANDLE_RETENTION_RUN_ON_STARTUP=false
SCHEDULER_TICK_INTERVAL_MS=60000
SCHEDULER_PROVIDER_FX_INTERVAL_SECONDS=3600
SCHEDULER_PROVIDER_BINANCE_INTERVAL_SECONDS=60
SCHEDULER_PROVIDER_KIS_INTERVAL_SECONDS=60
SCHEDULER_PROVIDER_INGESTION_RUN_ON_STARTUP=false
SCHEDULER_PROVIDER_KIS_MAX_SNAPSHOTS=500
SCHEDULER_LOCK_TTL_SECONDS=600
SCHEDULER_MAX_ATTEMPTS=1

# Production ranking scheduler example.
# Defaults above stay disabled; copy these non-secret values to the deployment env
# only when automatic current ranking refresh and scheduled equity snapshots are intended.
# SCHEDULER_ENABLED=true
# SCHEDULER_RANKING_ENABLED=true
# SCHEDULER_TICK_INTERVAL_MS=60000
# SCHEDULER_LOCK_TTL_SECONDS=600
# SCHEDULER_MAX_ATTEMPTS=1
#
# Minimal alternative accepted by the backend:
# ENABLE_RANKING_SCHEDULER=true
#
# Provider ingestion and reward marker scheduler flags are separate gates.

ENABLE_RANKING_SCHEDULER=false
ENABLE_PROVIDER_KIS_SCHEDULER=false
RANKING_REFRESH_INTERVAL_SECONDS=60
ENABLE_SEASON_LIFECYCLE_SCHEDULER=false
ENABLE_SEASON_SETTLEMENT_SCHEDULER=false
SEASON_SETTLEMENT_INTERVAL_SECONDS=60

# Limit-buy order foundation (phase 1: cash reservation only, NO automatic
# matching/execution). Default false. Keep DISABLED in production until the
# phase-2 execution engine ships: enabled, users can register GTC limit buys
# that reserve cash and stay `submitted` until canceled or cleaned up at
# season end / participant exclusion. Cancel and lifecycle cleanup work even
# while this flag is false.
#
# STRICTLY VALIDATED AT STARTUP. Accepted values are exactly true / false /
# 1 / 0, trimmed and case-insensitive (TRUE and False are fine). Omitting the
# variable entirely means false. ANY other value — yes, enabled, tru, or an
# explicitly empty value — aborts bootstrap with an "Invalid environment
# configuration" error instead of being silently read as off, because a flag
# an operator believes is on but is quietly off is the dangerous failure.
LIMIT_ORDER_ENABLED=false

# Opt-in switch for the limit-order PostgreSQL integration suites
# (reservation atomicity + create-vs-exclusion / create-vs-season-end races).
# Unset, those specs skip so `pnpm test` needs no database. Set to 1 with a
# migrated DATABASE_URL to run them:
#   LIMIT_ORDER_RESERVATION_DB_INTEGRATION=1 pnpm exec jest src/orders/limit-order-create-race.integration.spec.ts
# LIMIT_ORDER_RESERVATION_DB_INTEGRATION=1
