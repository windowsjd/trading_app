  limit_order_matcher
  limit_order_candle_reconciliation
}

enum MarketCandleSyncMode {
  initial
  incremental
  repair
}

enum MarketCandleSyncStatus {
  pending
  running
  completed
  failed
  canceled
}

enum OpsJobRunStatus {
  running
  succeeded
  failed
  skipped
