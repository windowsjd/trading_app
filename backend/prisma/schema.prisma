generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  suspended
  deleted
}

enum UserRole {
  user
  operator
  admin
}

enum RefreshTokenSessionStatus {
  active
  revoked
}

enum SeasonStatus {
  upcoming
  active
  ended
  settled
}

enum ParticipantStatus {
  registered
  active
  finished
  rewarded
  excluded
}

enum CurrencyCode {
  KRW
  USD
}

enum WalletTransactionDirection {
  credit
  debit
}

enum WalletTransactionType {
  initial_grant
  exchange_source
  exchange_target
  order_buy
  order_sell
  fee
  adjustment
  settlement
}

enum WalletTransactionReferenceType {
  season_join
  exchange_transaction
  order
  manual_adjustment
  settlement
}

enum SnapshotReason {
  season_join
  exchange_executed
  order_executed
  scheduled
  settlement
}

enum FxRateSourceType {
  official_batch
  provider_api
  admin_manual
}

enum FxExecuteRequestStatus {
  pending
  succeeded
  failed
}

enum AssetType {
  domestic_stock
  us_stock
  crypto
}

enum AssetPriceSourceType {
  official_batch
  provider_api
  admin_manual
}

enum SeasonRankingType {
  daily
  final
}

enum OrderSide {
  buy
  sell
}

enum OrderType {
  market
  limit
}

enum OrderStatus {
  submitted
  executed
  canceled
  rejected
}

enum QuoteType {
  fx
  order
}

enum QuoteStatus {
  active
  consumed
  expired
  canceled
}

enum BatchJobStatus {
  pending
  running
  succeeded
  failed
  skipped
}

enum BadgeType {
  tier_badge
  ranker_trophy
}

enum SeasonRewardType {
  internal
  badge
  trophy
}

enum RewardFulfillmentStatus {
  pending
  processing
  fulfilled
  failed
  canceled
}

enum OperatorAuditResult {
  success
  failure
}

enum OpsJobName {
  provider_fx_ingest
  provider_binance_ingest
  provider_kis_ingest
  daily_portfolio_snapshot
