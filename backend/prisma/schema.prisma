}

enum MarketCalendarMarket {
  KRX
  US
}

enum MarketSessionOverrideType {
  regular
  closed
  custom
}

enum OpsJobTrigger {
  scheduler
  operator
  manual_script
  test
  worker
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String     @map("password_hash")
  nickname        String     @unique
  profileImageUrl String?    @map("profile_image_url")
  status          UserStatus @default(active)
  role            UserRole   @default(user)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  seasonParticipants          SeasonParticipant[]
  fxExecuteRequests           FxExecuteRequest[]
  refreshTokenSessions        RefreshTokenSession[]
  userBadges                  UserBadge[]
  seasonRewards               SeasonReward[]
  operatorAuditLogs           OperatorAuditLog[]
  quotes                      Quote[]
  rewardFulfillmentTargets    RewardFulfillmentRequest[] @relation("RewardFulfillmentTargetUser")
  rewardFulfillmentsRequested RewardFulfillmentRequest[] @relation("RewardFulfillmentRequestedBy")
  rewardFulfillmentsProcessed RewardFulfillmentRequest[] @relation("RewardFulfillmentProcessedBy")
  rewardFulfillmentsCanceled  RewardFulfillmentRequest[] @relation("RewardFulfillmentCanceledBy")

  @@map("users")
}

model OperatorAuditLog {
  id           String              @id @default(uuid())
  actorUserId  String              @map("actor_user_id")
  actorRole    UserRole            @map("actor_role")
  action       String
  targetType   String?             @map("target_type")
  targetId     String?             @map("target_id")
  requestId    String?             @map("request_id")
  ipAddress    String?             @map("ip_address")
  userAgent    String?             @map("user_agent")
  metadataJson Json?               @map("metadata_json")
  result       OperatorAuditResult
  errorCode    String?             @map("error_code")
  createdAt    DateTime            @default(now()) @map("created_at")

  actor User @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([result, createdAt])
  @@index([targetType, targetId])
  @@map("operator_audit_logs")
}

model RefreshTokenSession {
  id                  String                    @id @default(uuid())
  userId              String                    @map("user_id")
  tokenHash           String                    @unique @map("token_hash")
  status              RefreshTokenSessionStatus @default(active)
  expiresAt           DateTime                  @map("expires_at")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  revokedAt           DateTime?                 @map("revoked_at")
  replacedBySessionId String?                   @map("replaced_by_session_id")
  userAgent           String?                   @map("user_agent")
  ipAddress           String?                   @map("ip_address")

  user                      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBySession         RefreshTokenSession?  @relation("RefreshTokenSessionReplacement", fields: [replacedBySessionId], references: [id], onDelete: SetNull)
  replacementSourceSessions RefreshTokenSession[] @relation("RefreshTokenSessionReplacement")

  @@index([userId])
  @@index([status, expiresAt])
  @@map("refresh_token_sessions")
}

model Season {
  id                String       @id @default(uuid())
  name              String
  status            SeasonStatus
  startAt           DateTime     @map("start_at")
  endAt             DateTime     @map("end_at")
  initialCapitalKrw Decimal      @map("initial_capital_krw") @db.Decimal(24, 8)
  tradeFeeRate      Decimal      @map("trade_fee_rate") @db.Decimal(10, 6)
  fxFeeRate         Decimal      @map("fx_fee_rate") @db.Decimal(10, 6)
  rewardPolicyJson  Json?        @map("reward_policy_json")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  participants              SeasonParticipant[]
  seasonRankings            SeasonRanking[]
  userBadges                UserBadge[]
  seasonRewards             SeasonReward[]
  rewardFulfillmentRequests RewardFulfillmentRequest[]

  @@map("seasons")
}

model SeasonParticipant {
  id                      String            @id @default(uuid())
  seasonId                String            @map("season_id")
  userId                  String            @map("user_id")
  joinedAt                DateTime          @map("joined_at")
  participantStatus       ParticipantStatus @default(registered) @map("participant_status")
  initialCapitalKrw       Decimal           @map("initial_capital_krw") @db.Decimal(24, 8)
  totalAssetKrw           Decimal           @map("total_asset_krw") @db.Decimal(24, 8)
  totalReturnRate         Decimal           @map("total_return_rate") @db.Decimal(12, 8)
  maxDrawdown             Decimal           @map("max_drawdown") @db.Decimal(12, 8)
  totalFillCount          Int               @default(0) @map("total_fill_count")
  currentRank             Int?              @map("current_rank")
  finalRank               Int?              @map("final_rank")
  finalTier               String?           @map("final_tier")
  rewardGrantedAt         DateTime?         @map("reward_granted_at")
  excludedAt              DateTime?         @map("excluded_at")
  excludedReason          String?           @map("excluded_reason")
  excludedByUserId        String?           @map("excluded_by_user_id")
  rankingHiddenAt         DateTime?         @map("ranking_hidden_at")
  rankingHiddenReason     String?           @map("ranking_hidden_reason")
  rankingHiddenByUserId   String?           @map("ranking_hidden_by_user_id")
  resultCorrectedAt       DateTime?         @map("result_corrected_at")
  resultCorrectedReason   String?           @map("result_corrected_reason")
  resultCorrectedByUserId String?           @map("result_corrected_by_user_id")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  season                    Season                     @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user                      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashWallets               CashWallet[]
  walletTransactions        WalletTransaction[]
  exchangeTransactions      ExchangeTransaction[]
  equitySnapshots           EquitySnapshot[]
  fxExecuteRequests         FxExecuteRequest[]
  positions                 Position[]
  orders                    Order[]
  quotes                    Quote[]
  dailyPortfolioSnapshots   DailyPortfolioSnapshot[]
  seasonRankings            SeasonRanking[]
  seasonRewards             SeasonReward[]
  rewardFulfillmentRequests RewardFulfillmentRequest[]

  @@unique([seasonId, userId])
  @@index([seasonId])
  @@index([seasonId, participantStatus])
  @@index([seasonId, rankingHiddenAt])
  @@index([userId])
  @@map("season_participants")
}

model Badge {
  id          String    @id @default(uuid())
  badgeType   BadgeType @map("badge_type")
  code        String    @unique
  name        String
  description String?
  iconUrl     String?   @map("icon_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  userBadges UserBadge[]

  @@index([badgeType])
  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  badgeId   String   @map("badge_id")
  seasonId  String   @map("season_id")
  awardedAt DateTime @map("awarded_at")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge  Badge  @relation(fields: [badgeId], references: [id], onDelete: Restrict)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId, seasonId])
  @@index([userId, awardedAt])
  @@index([badgeId])
  @@index([seasonId])
  @@map("user_badges")
}

model SeasonReward {
  id                   String           @id @default(uuid())
  seasonId             String           @map("season_id")
  seasonParticipantId  String           @map("season_participant_id")
  userId               String           @map("user_id")
  rewardType           SeasonRewardType @map("reward_type")
  rewardCode           String           @map("reward_code")
  rewardName           String           @map("reward_name")
  rewardValueJson      Json?            @map("reward_value_json")
  fulfillmentRequestId String?          @unique @map("fulfillment_request_id")
  grantedAt            DateTime         @map("granted_at")
  createdAt            DateTime         @default(now()) @map("created_at")

  season                    Season                     @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  seasonParticipant         SeasonParticipant          @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  user                      User                       @relation(fields: [userId], references: [id], onDelete: Restrict)
  fulfillmentRequest        RewardFulfillmentRequest?  @relation("SeasonRewardFulfillmentRequest", fields: [fulfillmentRequestId], references: [id], onDelete: SetNull)
  rewardFulfillmentRequests RewardFulfillmentRequest[] @relation("RewardFulfillmentRequestSeasonReward")

  @@unique([seasonParticipantId, rewardCode])
  @@index([seasonId, grantedAt])
  @@index([userId, grantedAt])
  @@index([rewardType, rewardCode])
  @@index([fulfillmentRequestId])
  @@map("season_rewards")
}

model RewardFulfillmentRequest {
  id                  String                  @id @default(uuid())
  seasonId            String                  @map("season_id")
  seasonParticipantId String                  @map("season_participant_id")
  userId              String                  @map("user_id")
  rewardType          SeasonRewardType        @map("reward_type")
  rewardCode          String                  @map("reward_code")
  rewardName          String                  @map("reward_name")
  rewardValueJson     Json?                   @map("reward_value_json")
  status              RewardFulfillmentStatus @default(pending)
  seasonRewardId      String?                 @map("season_reward_id")
  idempotencyKey      String                  @map("idempotency_key")
  requestHash         String                  @map("request_hash")
  requestedByUserId   String                  @map("requested_by_user_id")
  processedByUserId   String?                 @map("processed_by_user_id")
  canceledByUserId    String?                 @map("canceled_by_user_id")
  requestedAt         DateTime                @default(now()) @map("requested_at")
  processingStartedAt DateTime?               @map("processing_started_at")
  fulfilledAt         DateTime?               @map("fulfilled_at")
  failedAt            DateTime?               @map("failed_at")
  canceledAt          DateTime?               @map("canceled_at")
  errorCode           String?                 @map("error_code")
  errorMessage        String?                 @map("error_message")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")

  season            Season            @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  seasonParticipant SeasonParticipant @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  user              User              @relation("RewardFulfillmentTargetUser", fields: [userId], references: [id], onDelete: Restrict)
  seasonReward      SeasonReward?     @relation("RewardFulfillmentRequestSeasonReward", fields: [seasonRewardId], references: [id], onDelete: SetNull)
  requestedBy       User              @relation("RewardFulfillmentRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  processedBy       User?             @relation("RewardFulfillmentProcessedBy", fields: [processedByUserId], references: [id], onDelete: SetNull)
  canceledBy        User?             @relation("RewardFulfillmentCanceledBy", fields: [canceledByUserId], references: [id], onDelete: SetNull)
  seasonRewards     SeasonReward[]    @relation("SeasonRewardFulfillmentRequest")

  @@unique([requestedByUserId, idempotencyKey])
  @@unique([seasonParticipantId, rewardCode])
  @@index([seasonId, status])
  @@index([userId, status])
  @@index([status, createdAt])
  @@index([seasonRewardId])
  @@index([requestedByUserId, requestedAt])
  @@map("reward_fulfillment_requests")
}

model Asset {
  id                 String       @id @default(uuid())
  symbol             String
  name               String
  market             String
  currencyCode       CurrencyCode @map("currency_code")
  priceCurrency      CurrencyCode @default(KRW) @map("price_currency")
  settlementCurrency CurrencyCode @default(KRW) @map("settlement_currency")
  assetType          AssetType    @map("asset_type")
  isActive           Boolean      @default(true) @map("is_active")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  priceSnapshots           AssetPriceSnapshot[]
  orderbookSnapshots       AssetOrderbookSnapshot[]
  marketCandles            MarketCandle[]
  marketCandleSyncStates   MarketCandleSyncState[]
  positions                Position[]
  orders                   Order[]
  quotes                   Quote[]
  limitOrderCandleEvidence LimitOrderCandleEvidence[]
  finalizationCheckpoints  MarketCandleFinalizationCheckpoint[]

  @@unique([market, symbol])
  @@index([assetType, market])
  @@index([isActive])
  @@map("assets")
}

model AssetPriceSnapshot {
  id               String               @id @default(uuid())
  assetId          String               @map("asset_id")
  price            Decimal              @db.Decimal(24, 8)
  priceKrw         Decimal?             @map("price_krw") @db.Decimal(24, 8)
  currencyCode     CurrencyCode         @map("currency_code")
  sourceType       AssetPriceSourceType @map("source_type")
  sourceName       String?              @map("source_name")
  sourceTimestamp  DateTime?            @map("source_timestamp")
  effectiveAt      DateTime             @map("effective_at")
  capturedAt       DateTime             @map("captured_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  rawPayloadJson   Json?                @map("raw_payload_json")
  note             String?
  // Exact live-trade evidence used by the limit matcher. Existing display /
  // throttled snapshots leave these nullable; one provider event is shared by
  // every order it fills.
  providerEventKey String?              @unique @map("provider_event_key")
  providerEventAt  DateTime?            @map("provider_event_at")

  asset  Asset   @relation(fields: [assetId], references: [id], onDelete: Restrict)
  orders Order[]
  quotes Quote[]

  @@index([assetId, effectiveAt])
  @@index([assetId, capturedAt])
  @@index([sourceType, effectiveAt])
  @@index([providerEventAt])
  @@map("asset_price_snapshots")
}

model AssetOrderbookSnapshot {
  id             String               @id @default(uuid())
  assetId        String               @map("asset_id")
  sourceType     AssetPriceSourceType @map("source_type")
  sourceName     String               @map("source_name")
  bidPrice       Decimal              @map("bid_price") @db.Decimal(24, 8)
  bidQuantity    Decimal?             @map("bid_quantity") @db.Decimal(24, 8)
  askPrice       Decimal              @map("ask_price") @db.Decimal(24, 8)
  askQuantity    Decimal?             @map("ask_quantity") @db.Decimal(24, 8)
  spreadBps      Decimal?             @map("spread_bps") @db.Decimal(18, 8)
  currencyCode   CurrencyCode         @map("currency_code")
  effectiveAt    DateTime             @map("effective_at")
  capturedAt     DateTime             @map("captured_at")
  rawPayloadJson Json?                @map("raw_payload_json")
  createdAt      DateTime             @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@index([assetId, sourceName, effectiveAt])
  @@index([assetId, capturedAt])
  @@index([sourceType, effectiveAt])
  @@map("asset_orderbook_snapshots")
}

model MarketCandle {
  id              String    @id @default(uuid())
  assetId         String    @map("asset_id")
  // Stored as a plain string instead of a Prisma enum: API interval literals
  // ("5m", "1d", "1w") start with a digit and cannot be enum identifiers, and
  // later aggregation intervals (15m/30m/1h/4h) must be addable without an
  // ALTER TYPE migration. The allowlist is enforced by MarketCandlesRepository.
  interval        String
  // Candle window is [openTime, closeTime); both are UTC instants.
  openTime        DateTime  @map("open_time") @db.Timestamptz(3)
  closeTime       DateTime  @map("close_time") @db.Timestamptz(3)
  open            Decimal   @db.Decimal(24, 8)
  high            Decimal   @db.Decimal(24, 8)
  low             Decimal   @db.Decimal(24, 8)
  close           Decimal   @db.Decimal(24, 8)
  volume          Decimal   @db.Decimal(24, 8)
  amount          Decimal?  @db.Decimal(24, 8)
  isClosed        Boolean   @map("is_closed")
  sourceProvider  String    @map("source_provider")
  sourceUpdatedAt DateTime  @map("source_updated_at") @db.Timestamptz(3)
  // STORAGE-order position, assigned by the `market_candles_ingest_seq`
  // database trigger from a single sequence: on insert, and again whenever the
  // row changes in a way that can change a path-B matching decision (it becomes
  // closed, its low or its window moves).
  //
  // Path B scans by THIS column, not by openTime. openTime is market time and
  // says nothing about when a row appeared: a candle stored late — a provider
  // gap, a finalizer restart, a backfill — has an openTime the global watermark
  // has long passed, and scanning in market order skipped it forever. Assigned
  // by a trigger rather than by the application because market_candles has
  // several writers, including a raw bulk upsert.
  //
  // Nullable only so the column could be added without rewriting the table; the
  // trigger fills it for every row, and the migration backfilled the rest.
  ingestSeq       BigInt?   @map("ingest_seq")
  ingestSeqAt     DateTime? @map("ingest_seq_at") @db.Timestamptz(3)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  asset                 Asset                       @relation(fields: [assetId], references: [id], onDelete: Restrict)
  limitOrderEvidence    LimitOrderCandleEvidence[]
  limitOrderProcessedBy LimitOrderProcessedCandle[]

  @@unique([assetId, interval, openTime])
  @@index([interval, openTime])
  @@index([isClosed, openTime])
  // Path-B candle sweep: closed 5m rows of one asset ordered by window start.
  @@index([assetId, interval, isClosed, openTime])
  // Path-B storage-order sweep: bounded forward walk over newly stored rows.
  @@index([ingestSeq])
  @@map("market_candles")
}

// Persistent checkpoint for one candle sync run of a single asset/feed.
// `feed` is the stored interval literal ("5m", "1d", "1w") — a string for the
// same reason MarketCandle.interval is. cursorJson holds only provider-neutral
// resume state (dates/epoch cursors); credentials and raw provider payloads
// must never be stored here. Active-run uniqueness (at most one pending or
// running row per asset/feed) is enforced by a partial unique index that
// Prisma cannot express; see the migration SQL
// (market_candle_sync_states_active_unique).
model MarketCandleSyncState {
  id                   String                 @id @default(uuid())
  assetId              String                 @map("asset_id")
  feed                 String
  sourceProvider       String                 @map("source_provider")
  mode                 MarketCandleSyncMode
  status               MarketCandleSyncStatus @default(pending)
  // Target candle range, half-open [targetFrom, targetTo), UTC instants.
  targetFrom           DateTime               @map("target_from") @db.Timestamptz(3)
  targetTo             DateTime               @map("target_to") @db.Timestamptz(3)
  cursorJson           Json?                  @map("cursor_json")
  pagesFetched         Int                    @default(0) @map("pages_fetched")
  providerRowsReceived Int                    @default(0) @map("provider_rows_received")
  rowsAccepted         Int                    @default(0) @map("rows_accepted")
  rowsRejected         Int                    @default(0) @map("rows_rejected")
  rowsDuplicated       Int                    @default(0) @map("rows_duplicated")
  rowsWritten          Int                    @default(0) @map("rows_written")
  lastSuccessfulPageAt DateTime?              @map("last_successful_page_at") @db.Timestamptz(3)
  completedAt          DateTime?              @map("completed_at") @db.Timestamptz(3)
  // Coverage completeness is independent of `status`: `completed` records that
  // the run terminated normally, while coverageComplete=true additionally
  // asserts that the provider cursor confirmed the entire half-open
  // [targetFrom, targetTo) range. Rows created before this column existed keep
  // coverageComplete=false and are never used as serving coverage evidence.
  coverageComplete     Boolean                @default(false) @map("coverage_complete")
  completionReason     String?                @map("completion_reason")
  // Half-open [coveredFrom, coveredTo) instants actually confirmed by the
  // provider cursor so far (grows monotonically while the run pages).
  coveredFrom          DateTime?              @map("covered_from") @db.Timestamptz(3)
  coveredTo            DateTime?              @map("covered_to") @db.Timestamptz(3)
  errorCode            String?                @map("error_code")
  errorMessage         String?                @map("error_message")
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@index([assetId, feed, status])
  @@index([status, updatedAt])
  @@map("market_candle_sync_states")
}

// Operator-managed exception layer over the static per-year market calendar
// datasets (backend/src/orders/market-calendar/data). localDate is the
// exchange's local trading date (KRX: Asia/Seoul, US: America/New_York)
// stored as YYYY-MM-DD text so the exchange-local meaning never shifts with
// server/DB time zones; openTime/closeTime are exchange-local HHmmss text in
// the same canonical format the static datasets use. `regular` cancels a
// static closure/session override and forces the default session; `closed`
// forces a full-day closure; `custom` sets explicit open/close times (both
// required, open < close — enforced by CHECK constraints in the migration).
// An override never grants calendar coverage for its year: dates in years
// without a static dataset stay fail-closed (calendar_unavailable). Rows are
// deactivated (isActive=false) instead of deleted to preserve operational
// history.
model MarketSessionOverride {
  id              String                    @id @default(uuid())
  market          MarketCalendarMarket
  localDate       String                    @map("local_date")
  overrideType    MarketSessionOverrideType @map("override_type")
  openTime        String?                   @map("open_time")
  closeTime       String?                   @map("close_time")
  reason          String
  source          String?
  isActive        Boolean                   @default(true) @map("is_active")
  createdByUserId String                    @map("created_by_user_id")
  updatedByUserId String                    @map("updated_by_user_id")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  @@unique([market, localDate])
  @@index([isActive, market, localDate])
  @@index([localDate])
  @@map("market_session_overrides")
}

model Position {
  id                  String       @id @default(uuid())
  seasonParticipantId String       @map("season_participant_id")
  assetId             String       @map("asset_id")
  quantity            Decimal      @db.Decimal(24, 8)
  averageCost         Decimal      @map("average_cost") @db.Decimal(24, 8)
  currencyCode        CurrencyCode @map("currency_code")
  realizedPnl         Decimal      @default(0) @map("realized_pnl") @db.Decimal(24, 8)
  realizedPnlKrw      Decimal      @default(0) @map("realized_pnl_krw") @db.Decimal(24, 8)
  currentPriceLocal   Decimal?     @map("current_price_local") @db.Decimal(24, 8)
  currentPriceKrw     Decimal?     @map("current_price_krw") @db.Decimal(24, 8)
  marketValueLocal    Decimal?     @map("market_value_local") @db.Decimal(24, 8)
  marketValueKrw      Decimal?     @map("market_value_krw") @db.Decimal(24, 8)
  unrealizedPnlLocal  Decimal?     @map("unrealized_pnl_local") @db.Decimal(24, 8)
  unrealizedPnlKrw    Decimal?     @map("unrealized_pnl_krw") @db.Decimal(24, 8)
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  seasonParticipant SeasonParticipant @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  asset             Asset             @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@unique([seasonParticipantId, assetId])
  @@index([seasonParticipantId])
  @@index([assetId])
  @@map("positions")
}

model Order {
  id                         String       @id @default(uuid())
  seasonParticipantId        String       @map("season_participant_id")
  assetId                    String       @map("asset_id")
  quoteId                    String?      @unique @map("quote_id")
  side                       OrderSide
  orderType                  OrderType    @map("order_type")
  status                     OrderStatus  @default(submitted)
  quantity                   Decimal      @db.Decimal(24, 8)
  limitPrice                 Decimal?     @map("limit_price") @db.Decimal(24, 8)
  executedPrice              Decimal?     @map("executed_price") @db.Decimal(24, 8)
  currencyCode               CurrencyCode @map("currency_code")
  grossAmount                Decimal?     @map("gross_amount") @db.Decimal(24, 8)
  feeAmount                  Decimal?     @map("fee_amount") @db.Decimal(24, 8)
  netAmount                  Decimal?     @map("net_amount") @db.Decimal(24, 8)
  assetPriceSnapshotId       String?      @map("asset_price_snapshot_id")
  fxRateSnapshotId           String?      @map("fx_rate_snapshot_id")
  idempotencyKey             String?      @map("idempotency_key")
  requestHash                String?      @map("request_hash")
  responsePayloadJson        Json?        @map("response_payload_json")
  // Limit-buy reservation bookkeeping (null for market orders): the cash
  // amount locked at submit time, the fee rate captured for the future
  // execution phase, and when the reservation was released (cancel/cleanup).
  reservedAmount             Decimal?     @map("reserved_amount") @db.Decimal(24, 8)
  reservationFeeRate         Decimal?     @map("reservation_fee_rate") @db.Decimal(10, 6)
  reservationReleasedAt      DateTime?    @map("reservation_released_at")
  cancelReason               String?      @map("cancel_reason")
  // Path-A matching activation and exact trigger evidence. The Redis stream
  // cursor, rather than a cross-host wall clock, excludes pre-submission
  // events. These remain null for market orders and phase-1-only limit rows.
  matchingActivatedAt        DateTime?    @map("matching_activated_at")
  matchingActivationStreamId String?      @map("matching_activation_stream_id")
  // Path-B activation boundary: the first closed 5m candle window this order
  // may be filled from, rounded UP to a 5-minute boundary so the partially
  // elapsed candle the order was submitted into is never used. NULL means the
  // order predates path B (or was created while automatic matching was off)
  // and is never retroactively activated against historical candles.
  candleMatchingEligibleFrom DateTime?    @map("candle_matching_eligible_from")
  triggerEventId             String?      @map("trigger_event_id")
  triggerEventAt             DateTime?    @map("trigger_event_at")
  limitOrderCandleEvidenceId String?      @map("limit_order_candle_evidence_id")
  matchedAt                  DateTime?    @map("matched_at")
  matchingSource             String?      @map("matching_source")
  submittedAt                DateTime     @map("submitted_at")
  executedAt                 DateTime?    @map("executed_at")
  canceledAt                 DateTime?    @map("canceled_at")
  rejectedAt                 DateTime?    @map("rejected_at")
  rejectReason               String?      @map("reject_reason")
  createdAt                  DateTime     @default(now()) @map("created_at")
  updatedAt                  DateTime     @updatedAt @map("updated_at")

  seasonParticipant  SeasonParticipant         @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  asset              Asset                     @relation(fields: [assetId], references: [id], onDelete: Restrict)
  quote              Quote?                    @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  assetPriceSnapshot AssetPriceSnapshot?       @relation(fields: [assetPriceSnapshotId], references: [id], onDelete: Restrict)
  fxRateSnapshot     FxRateSnapshot?           @relation(fields: [fxRateSnapshotId], references: [id], onDelete: Restrict)
  candleEvidence     LimitOrderCandleEvidence? @relation(fields: [limitOrderCandleEvidenceId], references: [id], onDelete: Restrict)

  @@unique([seasonParticipantId, idempotencyKey])
  @@index([seasonParticipantId, submittedAt])
  @@index([seasonParticipantId, status])
  @@index([assetId])
  @@index([quoteId])
  @@index([assetPriceSnapshotId])
  @@index([fxRateSnapshotId])
  @@index([submittedAt])
  @@index([status])
  @@index([triggerEventId])
  @@index([limitOrderCandleEvidenceId])
  @@map("orders")
}

model CashWallet {
  id                  String       @id @default(uuid())
  seasonParticipantId String       @map("season_participant_id")
  currencyCode        CurrencyCode @map("currency_code")
  balanceAmount       Decimal      @map("balance_amount") @db.Decimal(24, 8)
  // Cash locked by submitted limit-buy orders. Never subtracted from total
  // asset valuation; availableAmount (= balance - reserved) is derived at
  // read time and is the ceiling for every ordinary cash debit.
  reservedAmount      Decimal      @default(0) @map("reserved_amount") @db.Decimal(24, 8)
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  seasonParticipant  SeasonParticipant   @relation(fields: [seasonParticipantId], references: [id], onDelete: Cascade)
  walletTransactions WalletTransaction[]

  @@unique([seasonParticipantId, currencyCode])
  @@index([seasonParticipantId])
  @@map("cash_wallets")
}

model WalletTransaction {
  id                  String                         @id @default(uuid())
  seasonParticipantId String                         @map("season_participant_id")
  walletId            String                         @map("wallet_id")
  currencyCode        CurrencyCode                   @map("currency_code")
  direction           WalletTransactionDirection
  txType              WalletTransactionType          @map("tx_type")
  referenceType       WalletTransactionReferenceType @map("reference_type")
  referenceId         String?                        @map("reference_id")
  amount              Decimal                        @db.Decimal(24, 8)
  balanceAfter        Decimal                        @map("balance_after") @db.Decimal(24, 8)
  occurredAt          DateTime                       @map("occurred_at")
  createdAt           DateTime                       @default(now()) @map("created_at")

  seasonParticipant SeasonParticipant @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  wallet            CashWallet        @relation(fields: [walletId], references: [id], onDelete: Restrict)

  @@index([seasonParticipantId, occurredAt])
  @@index([walletId, occurredAt])
  @@index([referenceType, referenceId])
  @@map("wallet_transactions")
}

model ExchangeTransaction {
  id                  String       @id @default(uuid())
  seasonParticipantId String       @map("season_participant_id")
  fxRateSnapshotId    String?      @map("fx_rate_snapshot_id")
  fromCurrency        CurrencyCode @map("from_currency")
  toCurrency          CurrencyCode @map("to_currency")
  sourceAmount        Decimal      @map("source_amount") @db.Decimal(24, 8)
  grossTargetAmount   Decimal      @map("gross_target_amount") @db.Decimal(24, 8)
  feeRate             Decimal      @map("fee_rate") @db.Decimal(10, 6)
  feeAmount           Decimal      @map("fee_amount") @db.Decimal(24, 8)
  feeCurrency         CurrencyCode @map("fee_currency")
  appliedRate         Decimal      @map("applied_rate") @db.Decimal(18, 8)
  netTargetAmount     Decimal      @map("net_target_amount") @db.Decimal(24, 8)
  executedAt          DateTime     @map("executed_at")
  createdAt           DateTime     @default(now()) @map("created_at")

  seasonParticipant SeasonParticipant  @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  fxRateSnapshot    FxRateSnapshot?    @relation(fields: [fxRateSnapshotId], references: [id], onDelete: Restrict)
  fxExecuteRequests FxExecuteRequest[]

  @@index([seasonParticipantId, executedAt])
  @@index([fxRateSnapshotId])
  @@index([fromCurrency, toCurrency, executedAt])
  @@map("exchange_transactions")
}

model FxRateSnapshot {
  id               String           @id @default(uuid())
  baseCurrency     CurrencyCode     @map("base_currency")
  quoteCurrency    CurrencyCode     @map("quote_currency")
  rate             Decimal          @db.Decimal(18, 8)
  sourceType       FxRateSourceType @map("source_type")
  sourceName       String?          @map("source_name")
  sourceTimestamp  DateTime?        @map("source_timestamp")
  effectiveAt      DateTime         @map("effective_at")
  capturedAt       DateTime         @map("captured_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  rawPayloadJson   Json?            @map("raw_payload_json")
  approvedByUserId String?          @map("approved_by_user_id")
  note             String?

  exchangeTransactions ExchangeTransaction[]
  orders               Order[]
  quotes               Quote[]

  @@index([baseCurrency, quoteCurrency, effectiveAt])
  @@index([baseCurrency, quoteCurrency, capturedAt])
  @@index([sourceType, effectiveAt])
  @@map("fx_rate_snapshots")
}

model Quote {
  id                   String        @id @default(uuid())
  userId               String        @map("user_id")
  seasonParticipantId  String?       @map("season_participant_id")
  quoteType            QuoteType     @map("quote_type")
  status               QuoteStatus   @default(active)
  assetId              String?       @map("asset_id")
  side                 OrderSide?
  orderType            OrderType?    @map("order_type")
  quantity             Decimal?      @db.Decimal(24, 8)
  limitPrice           Decimal?      @map("limit_price") @db.Decimal(24, 8)
  fromCurrency         CurrencyCode? @map("from_currency")
  toCurrency           CurrencyCode? @map("to_currency")
  sourceAmount         Decimal?      @map("source_amount") @db.Decimal(24, 8)
  targetAmount         Decimal?      @map("target_amount") @db.Decimal(24, 8)
  currencyCode         CurrencyCode? @map("currency_code")
  quotedPrice          Decimal?      @map("quoted_price") @db.Decimal(24, 8)
  quotedRate           Decimal?      @map("quoted_rate") @db.Decimal(18, 8)
  // Limit-buy reservation basis pinned AT QUOTE TIME (null on market/FX
  // quotes). Create reserves exactly these amounts, so a Season.tradeFeeRate
  // change between quote and create can never move the user's reservation.
  quotedFeeRate        Decimal?      @map("quoted_fee_rate") @db.Decimal(10, 6)
  quotedGrossAmount    Decimal?      @map("quoted_gross_amount") @db.Decimal(24, 8)
  quotedFeeAmount      Decimal?      @map("quoted_fee_amount") @db.Decimal(24, 8)
  quotedReservedAmount Decimal?      @map("quoted_reserved_amount") @db.Decimal(24, 8)
  assetPriceSnapshotId String?       @map("asset_price_snapshot_id")
  fxRateSnapshotId     String?       @map("fx_rate_snapshot_id")
  assetPriceSourceJson Json?         @map("asset_price_source_json")
  fxRateSourceJson     Json?         @map("fx_rate_source_json")
  maxChangeBps         Decimal       @map("max_change_bps") @db.Decimal(10, 4)
  expiresAt            DateTime      @map("expires_at")
  requestHash          String        @map("request_hash")
  consumedAt           DateTime?     @map("consumed_at")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  user               User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  seasonParticipant  SeasonParticipant?  @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  asset              Asset?              @relation(fields: [assetId], references: [id], onDelete: Restrict)
  assetPriceSnapshot AssetPriceSnapshot? @relation(fields: [assetPriceSnapshotId], references: [id], onDelete: Restrict)
  fxRateSnapshot     FxRateSnapshot?     @relation(fields: [fxRateSnapshotId], references: [id], onDelete: Restrict)
  orders             Order[]

  @@index([userId, createdAt])
  @@index([seasonParticipantId, createdAt])
  @@index([quoteType, status, expiresAt])
  @@index([requestHash])
  @@index([assetId, createdAt])
  @@index([fxRateSnapshotId])
  @@index([assetPriceSnapshotId])
  @@map("quotes")
}

