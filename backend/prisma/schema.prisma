// Durable event-level dedupe. A price event can fill many orders, so the
// event id cannot be unique on Order. Recording completion here prevents a
// later duplicate XADD from filling orders created after the original event.
model LimitOrderProcessedEvent {
  eventId       String   @id @map("event_id")
  firstStreamId String   @map("first_stream_id")
  receivedAt    DateTime @map("received_at")
  processedAt   DateTime @map("processed_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([processedAt])
  @@map("limit_order_processed_events")
}

// Path-B (closed 5m candle safety net) trigger evidence. One row per
// (candle, policy) is shared by every order the candle fills — the candle is
// the evidence, and MarketCandle rows are immutable once finalized, so the
// duplicated columns exist only so the fill reason stays reproducible even if
// retention later removes the candle row.
// One IMMUTABLE evidence row per (candle, storage revision). A correction to
// an already-processed candle re-sequences the row (new ingestSeq), and any
// fill it newly justifies gets a NEW evidence row carrying the corrected low;
// evidence created for earlier fills is never updated or shared across
// revisions, so the audit trail of what each order actually filled against is
// preserved verbatim.
model LimitOrderCandleEvidence {
  id                   String   @id @default(uuid())
  marketCandleId       String   @map("market_candle_id")
  // Storage revision (MarketCandle.ingestSeq) this evidence captures.
  // Existing rows were backfilled with the candle's revision at migration
  // time.
  candleIngestSeq      BigInt   @map("candle_ingest_seq")
  assetId              String   @map("asset_id")
  interval             String
  openTime             DateTime @map("open_time") @db.Timestamptz(3)
  closeTime            DateTime @map("close_time") @db.Timestamptz(3)
  triggerLowPrice      Decimal  @map("trigger_low_price") @db.Decimal(24, 8)
  // Always 'limit_price': a 5m low proves the limit was touched, never the
  // price a fill could actually have been obtained at.
  executionPricePolicy String   @map("execution_price_policy")
  provider             String
  sourceName           String   @map("source_name")
  sourceUpdatedAt      DateTime @map("source_updated_at") @db.Timestamptz(3)
  finalizedAt          DateTime @map("finalized_at") @db.Timestamptz(3)
  policyVersion        Int      @map("policy_version")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  marketCandle MarketCandle @relation(fields: [marketCandleId], references: [id], onDelete: Restrict)
  asset        Asset        @relation(fields: [assetId], references: [id], onDelete: Restrict)
  orders       Order[]

  @@unique([marketCandleId, candleIngestSeq])
  @@index([assetId, openTime])
  @@map("limit_order_candle_evidences")
}

// Durable path-B dedupe. Written only after EVERY candidate batch for the
// candle committed, so a crash mid-sweep re-runs the candle (already executed
// orders are skipped by the status guard) instead of silently dropping it.
//
// REVISION-AWARE: `candleIngestSeq` records WHICH storage revision of the
// candle was processed (MarketCandle.ingestSeq is re-assigned whenever a
// correction changes what the window could fill). A candle whose current
// ingestSeq is above the processed one is a NEW revision and is re-examined;
// the status guard on orders makes the re-run additive-only (already executed
// orders can never fill twice). One row per candle records the LATEST
// processed revision; per-revision audit lives in the evidence rows, which
// are immutable and revision-scoped.
model LimitOrderProcessedCandle {
  marketCandleId    String   @id @map("market_candle_id")
  assetId           String   @map("asset_id")
  interval          String
  openTime          DateTime @map("open_time") @db.Timestamptz(3)
  closeTime         DateTime @map("close_time") @db.Timestamptz(3)
  processedAt       DateTime @map("processed_at") @db.Timestamptz(3)
  matchedOrderCount Int      @map("matched_order_count")
  result            String
  skipReason        String?  @map("skip_reason")
  // Storage revision (MarketCandle.ingestSeq) this row covers. Existing rows
  // were backfilled with the candle's revision at migration time.
  candleIngestSeq   BigInt   @map("candle_ingest_seq")
  // How many revisions of this candle have been processed; audit only.
  revisionCount     Int      @default(1) @map("revision_count")
  firstProcessedAt  DateTime @default(now()) @map("first_processed_at") @db.Timestamptz(3)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  marketCandle MarketCandle @relation(fields: [marketCandleId], references: [id], onDelete: Restrict)

  @@index([assetId, openTime])
  @@index([processedAt])
  @@map("limit_order_processed_candles")
}

// Per-asset path-B WINDOW COMPLETION cursor (finalization checkpoint).
//
// `market_candles.ingest_seq` tracks rows that EXIST; it cannot see a window
// whose row was never written — a finalizer that skipped the window, a feed
// gap, a permanently failed DB write, or a genuine no-trade window all look
// identical: no row. This cursor is the durable protocol that tells them
// apart, per asset, in market-time order:
//
//   every 5m window with closeTime <= finalizedThroughCloseTime is accounted
//   for: a canonical closed row exists, OR the provider confirmed the range
//   with no candle (explicit no-trade), OR the window lies outside the
//   market session, OR it predates the asset's earliest activated order.
//
// The cursor never advances over a window it cannot account for; that window
// is recorded as PENDING (bounded REST-repair retries) and, if retention
// passes it unresolved, as a sticky per-asset GAP. Rows only ever exist for
// assets with activated path-B orders — nothing else is owed completion.
model MarketCandleFinalizationCheckpoint {
  assetId                   String    @map("asset_id")
  interval                  String
  // Every window with closeTime <= this value is accounted for. Anchored at
  // the asset's earliest activated order window on bootstrap.
  finalizedThroughOpenTime  DateTime? @map("finalized_through_open_time") @db.Timestamptz(3)
  finalizedThroughCloseTime DateTime  @map("finalized_through_close_time") @db.Timestamptz(3)
  lastAdvancedAt            DateTime? @map("last_advanced_at") @db.Timestamptz(3)
  lastEvaluatedAt           DateTime? @map("last_evaluated_at") @db.Timestamptz(3)
  // First window the cursor cannot account for yet. Bounded retries; its AGE
  // is what the asset-scoped health gate turns into FINALIZER_STALE.
  pendingWindowOpenTime     DateTime? @map("pending_window_open_time") @db.Timestamptz(3)
  pendingSince              DateTime? @map("pending_since") @db.Timestamptz(3)
  pendingAttemptCount       Int       @default(0) @map("pending_attempt_count")
  lastErrorCode             String?   @map("last_error_code")
  degradedReason            String?   @map("degraded_reason")
  // Sticky per-asset alarm: retention passed an unresolved window. Only an
  // operator clears it; the loss cannot be repaired.
  gapDetectedAt             DateTime? @map("gap_detected_at") @db.Timestamptz(3)
  gapFromOpenTime           DateTime? @map("gap_from_open_time") @db.Timestamptz(3)
  gapToOpenTime             DateTime? @map("gap_to_open_time") @db.Timestamptz(3)
  // Audit counters: windows certified WITHOUT a candle row.
  noTradeWindowCount        Int       @default(0) @map("no_trade_window_count")
  outsideSessionWindowCount Int       @default(0) @map("outside_session_window_count")
  repairedWindowCount       Int       @default(0) @map("repaired_window_count")
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                 DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@id([assetId, interval])
  @@index([pendingSince])
  @@index([gapDetectedAt])
  @@map("market_candle_finalization_checkpoints")
}

// Durable path-B scan position. Replaces the sliding `now - lookbackMs` window,
// which silently dropped any candle that stayed unprocessed longer than the
// lookback: once the window moved past it, nothing ever looked at it again.
//
// The watermark is a POSITION in the canonical (openTime, id) ordering of
// closed 5m candles. Its invariant is:
//
//   every closed 5m candle at or before the watermark is either recorded in
//   limit_order_processed_candles, or recorded in limit_order_deferred_candles,
//   or provably had no order that could ever match it.
//
// It therefore only advances over work that became DURABLE, never merely over
// elapsed time. One row per scope; the scope is the interval literal, so a
// later 1m/15m path-B variant gets its own independent position.
model LimitOrderReconciliationCheckpoint {
  scope                      String    @id
  interval                   String
  // NULL until the first bootstrap. `watermarkCandleId` is NULL when the
  // position is a pure time bound (bootstrap, or a gap re-anchor) rather than
  // a concrete candle row.
  watermarkOpenTime          DateTime? @map("watermark_open_time") @db.Timestamptz(3)
  watermarkCandleId          String?   @map("watermark_candle_id")
  // STORAGE-order scan position over MarketCandle.ingestSeq. This — not the
  // market-time watermark above — is what the forward scan reads from, so a
  // candle stored long after its window closed is still reached. The
  // market-time watermark remains the bootstrap anchor and the retention-gap
  // marker.
  watermarkIngestSeq         BigInt?   @map("watermark_ingest_seq")
  // Two-phase advance guard. A sequence value is assigned when a row is
  // INSERTED but only becomes visible when its transaction COMMITS, so the
  // highest visible value may still have uncommitted holes below it. The
  // highest value observed by a run is recorded here and only becomes eligible
  // as a watermark ceiling on a LATER run, once every write transaction that
  // was in flight at the observation has resolved.
  pendingIngestSeq           BigInt?   @map("pending_ingest_seq")
  pendingIngestSeqObservedAt DateTime? @map("pending_ingest_seq_observed_at") @db.Timestamptz(3)
  lastScannedIngestSeq       BigInt?   @map("last_scanned_ingest_seq")
  lastScannedOpenTime        DateTime? @map("last_scanned_open_time") @db.Timestamptz(3)
  lastScannedCloseTime       DateTime? @map("last_scanned_close_time") @db.Timestamptz(3)
  lastRunAt                  DateTime? @map("last_run_at") @db.Timestamptz(3)
  lastSuccessfulRunAt        DateTime? @map("last_successful_run_at") @db.Timestamptz(3)
  // Sticky operational alarm. Cleared only by an operator (or by the documented
  // recovery procedure), never by the sweep itself: a gap means candles were
  // retention-deleted before path B could look at them, which cannot be undone.
  degradedReason             String?   @map("degraded_reason")
  gapDetectedAt              DateTime? @map("gap_detected_at") @db.Timestamptz(3)
  gapFromOpenTime            DateTime? @map("gap_from_open_time") @db.Timestamptz(3)
  gapToOpenTime              DateTime? @map("gap_to_open_time") @db.Timestamptz(3)
  // Reservation mismatches are an unresolved financial inconsistency that never
  // self-heals; a repeated count is what turns the log line into a gate.
  reservationMismatchCount   Int       @default(0) @map("reservation_mismatch_count")
  lastReservationMismatchAt  DateTime? @map("last_reservation_mismatch_at") @db.Timestamptz(3)
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("limit_order_reconciliation_checkpoints")
}

// Durable retry queue for candles the sweep could not finish. A candle is
// enqueued here BEFORE the watermark is allowed to pass it, so a transient
// failure delays exactly one candle instead of blocking every later candle
// (head-of-line) or losing it once the old lookback window slid past.
//
// `marketCandleId` is intentionally NOT a foreign key: a deferred candle that
// retention removes must be detectable as a gap, and an FK would instead make
// the retention job fail.
model LimitOrderDeferredCandle {
  marketCandleId   String   @id @map("market_candle_id")
  assetId          String   @map("asset_id")
  interval         String
  openTime         DateTime @map("open_time") @db.Timestamptz(3)
  closeTime        DateTime @map("close_time") @db.Timestamptz(3)
  // 'deferred' — still retryable; 'permanent' — retry budget exhausted or the
  // candle row is gone. Both keep blocking-worthy backlog visible to the gate.
  status           String   @default("deferred")
  firstDeferredAt  DateTime @map("first_deferred_at") @db.Timestamptz(3)
  lastDeferredAt   DateTime @map("last_deferred_at") @db.Timestamptz(3)
  attemptCount     Int      @default(1) @map("attempt_count")
  lastErrorCode    String?  @map("last_error_code")
  lastErrorMessage String?  @map("last_error_message")
  nextRetryAt      DateTime @map("next_retry_at") @db.Timestamptz(3)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([status, nextRetryAt])
  @@index([status, firstDeferredAt])
  @@index([assetId, openTime])
  @@map("limit_order_deferred_candles")
}
