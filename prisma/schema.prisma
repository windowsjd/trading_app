generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  suspended
  deleted
}

enum RefreshTokenSessionStatus {
  active
  revoked
}

enum SeasonStatus {
  upcoming
  active
  ended
  settled
}

enum ParticipantStatus {
  registered
  active
  finished
  rewarded
}

enum CurrencyCode {
  KRW
  USD
}

enum WalletTransactionDirection {
  credit
  debit
}

enum WalletTransactionType {
  initial_grant
  exchange_source
  exchange_target
  order_buy
  order_sell
  fee
  adjustment
  settlement
}

enum WalletTransactionReferenceType {
  season_join
  exchange_transaction
  order
  manual_adjustment
  settlement
}

enum SnapshotReason {
  season_join
  exchange_executed
  order_executed
  scheduled
  settlement
}

enum FxRateSourceType {
  official_batch
  provider_api
  admin_manual
}

enum FxExecuteRequestStatus {
  pending
  succeeded
  failed
}

enum AssetType {
  domestic_stock
  us_stock
  crypto
}

enum AssetPriceSourceType {
  official_batch
  provider_api
  admin_manual
}

enum SeasonRankingType {
  daily
  final
}

enum OrderSide {
  buy
  sell
}

enum OrderType {
  market
  limit
}

enum OrderStatus {
  submitted
  executed
  canceled
  rejected
}

enum BatchJobStatus {
  pending
  running
  succeeded
  failed
  skipped
}

enum BadgeType {
  tier_badge
  ranker_trophy
}

enum SeasonRewardType {
  badge
  trophy
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String     @map("password_hash")
  nickname        String     @unique
  profileImageUrl String?    @map("profile_image_url")
  status          UserStatus @default(active)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  seasonParticipants   SeasonParticipant[]
  fxExecuteRequests    FxExecuteRequest[]
  refreshTokenSessions RefreshTokenSession[]
  userBadges           UserBadge[]
  seasonRewards        SeasonReward[]

  @@map("users")
}

model RefreshTokenSession {
  id                  String                    @id @default(uuid())
  userId              String                    @map("user_id")
  tokenHash           String                    @unique @map("token_hash")
  status              RefreshTokenSessionStatus @default(active)
  expiresAt           DateTime                  @map("expires_at")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  revokedAt           DateTime?                 @map("revoked_at")
  replacedBySessionId String?                   @map("replaced_by_session_id")
  userAgent           String?                   @map("user_agent")
  ipAddress           String?                   @map("ip_address")

  user                      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBySession         RefreshTokenSession?  @relation("RefreshTokenSessionReplacement", fields: [replacedBySessionId], references: [id], onDelete: SetNull)
  replacementSourceSessions RefreshTokenSession[] @relation("RefreshTokenSessionReplacement")

  @@index([userId])
  @@index([status, expiresAt])
  @@map("refresh_token_sessions")
}

model Season {
  id                String       @id @default(uuid())
  name              String
  status            SeasonStatus
  startAt           DateTime     @map("start_at")
  endAt             DateTime     @map("end_at")
  initialCapitalKrw Decimal      @map("initial_capital_krw") @db.Decimal(24, 8)
  tradeFeeRate      Decimal      @map("trade_fee_rate") @db.Decimal(10, 6)
  fxFeeRate         Decimal      @map("fx_fee_rate") @db.Decimal(10, 6)
  rewardPolicyJson  Json?        @map("reward_policy_json")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  participants   SeasonParticipant[]
  seasonRankings SeasonRanking[]
  userBadges     UserBadge[]
  seasonRewards  SeasonReward[]

  @@map("seasons")
}

model SeasonParticipant {
  id                String            @id @default(uuid())
  seasonId          String            @map("season_id")
  userId            String            @map("user_id")
  joinedAt          DateTime          @map("joined_at")
  participantStatus ParticipantStatus @default(registered) @map("participant_status")
  initialCapitalKrw Decimal           @map("initial_capital_krw") @db.Decimal(24, 8)
  totalAssetKrw     Decimal           @map("total_asset_krw") @db.Decimal(24, 8)
  totalReturnRate   Decimal           @map("total_return_rate") @db.Decimal(12, 8)
  maxDrawdown       Decimal           @map("max_drawdown") @db.Decimal(12, 8)
  totalFillCount    Int               @default(0) @map("total_fill_count")
  currentRank       Int?              @map("current_rank")
  finalRank         Int?              @map("final_rank")
  finalTier         String?           @map("final_tier")
  rewardGrantedAt   DateTime?         @map("reward_granted_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  season                  Season                   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashWallets             CashWallet[]
  walletTransactions      WalletTransaction[]
  exchangeTransactions    ExchangeTransaction[]
  equitySnapshots         EquitySnapshot[]
  fxExecuteRequests       FxExecuteRequest[]
  positions               Position[]
  orders                  Order[]
  dailyPortfolioSnapshots DailyPortfolioSnapshot[]
  seasonRankings          SeasonRanking[]
  seasonRewards           SeasonReward[]

  @@unique([seasonId, userId])
  @@index([seasonId])
  @@index([userId])
  @@map("season_participants")
}

model Badge {
  id          String    @id @default(uuid())
  badgeType   BadgeType @map("badge_type")
  code        String    @unique
  name        String
  description String?
  iconUrl     String?   @map("icon_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  userBadges UserBadge[]

  @@index([badgeType])
  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  badgeId   String   @map("badge_id")
  seasonId  String   @map("season_id")
  awardedAt DateTime @map("awarded_at")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge  Badge  @relation(fields: [badgeId], references: [id], onDelete: Restrict)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId, seasonId])
  @@index([userId, awardedAt])
  @@index([badgeId])
  @@index([seasonId])
  @@map("user_badges")
}

model SeasonReward {
  id                  String           @id @default(uuid())
  seasonId            String           @map("season_id")
  seasonParticipantId String           @map("season_participant_id")
  userId              String           @map("user_id")
  rewardType          SeasonRewardType @map("reward_type")
  rewardCode          String           @map("reward_code")
  rewardName          String           @map("reward_name")
  rewardValueJson     Json?            @map("reward_value_json")
  grantedAt           DateTime         @map("granted_at")
  createdAt           DateTime         @default(now()) @map("created_at")

  season            Season            @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  seasonParticipant SeasonParticipant @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  user              User              @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([seasonParticipantId, rewardCode])
  @@index([seasonId, grantedAt])
  @@index([userId, grantedAt])
  @@index([rewardType, rewardCode])
  @@map("season_rewards")
}

model Asset {
  id           String       @id @default(uuid())
  symbol       String
  name         String
  market       String
  currencyCode CurrencyCode @map("currency_code")
  assetType    AssetType    @map("asset_type")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  priceSnapshots AssetPriceSnapshot[]
  positions      Position[]
  orders         Order[]

  @@unique([market, symbol])
  @@index([assetType, market])
  @@index([isActive])
  @@map("assets")
}

model AssetPriceSnapshot {
  id              String               @id @default(uuid())
  assetId         String               @map("asset_id")
  price           Decimal              @db.Decimal(24, 8)
  currencyCode    CurrencyCode         @map("currency_code")
  sourceType      AssetPriceSourceType @map("source_type")
  sourceName      String?              @map("source_name")
  sourceTimestamp DateTime?            @map("source_timestamp")
  effectiveAt     DateTime             @map("effective_at")
  capturedAt      DateTime             @map("captured_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  rawPayloadJson  Json?                @map("raw_payload_json")
  note            String?

  asset  Asset   @relation(fields: [assetId], references: [id], onDelete: Restrict)
  orders Order[]

  @@index([assetId, effectiveAt])
  @@index([assetId, capturedAt])
  @@index([sourceType, effectiveAt])
  @@map("asset_price_snapshots")
}

model Position {
  id                  String       @id @default(uuid())
  seasonParticipantId String       @map("season_participant_id")
  assetId             String       @map("asset_id")
  quantity            Decimal      @db.Decimal(24, 8)
  averageCost         Decimal      @map("average_cost") @db.Decimal(24, 8)
  currencyCode        CurrencyCode @map("currency_code")
  realizedPnl         Decimal      @default(0) @map("realized_pnl") @db.Decimal(24, 8)
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  seasonParticipant SeasonParticipant @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  asset             Asset             @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@unique([seasonParticipantId, assetId])
  @@index([seasonParticipantId])
  @@index([assetId])
  @@map("positions")
}

model Order {
  id                   String       @id @default(uuid())
  seasonParticipantId  String       @map("season_participant_id")
  assetId              String       @map("asset_id")
  side                 OrderSide
  orderType            OrderType    @map("order_type")
  status               OrderStatus  @default(submitted)
  quantity             Decimal      @db.Decimal(24, 8)
  limitPrice           Decimal?     @map("limit_price") @db.Decimal(24, 8)
  executedPrice        Decimal?     @map("executed_price") @db.Decimal(24, 8)
  currencyCode         CurrencyCode @map("currency_code")
  grossAmount          Decimal?     @map("gross_amount") @db.Decimal(24, 8)
  feeAmount            Decimal?     @map("fee_amount") @db.Decimal(24, 8)
  netAmount            Decimal?     @map("net_amount") @db.Decimal(24, 8)
  assetPriceSnapshotId String?      @map("asset_price_snapshot_id")
  fxRateSnapshotId     String?      @map("fx_rate_snapshot_id")
  idempotencyKey       String?      @map("idempotency_key")
  requestHash          String?      @map("request_hash")
  responsePayloadJson  Json?        @map("response_payload_json")
  submittedAt          DateTime     @map("submitted_at")
  executedAt           DateTime?    @map("executed_at")
  canceledAt           DateTime?    @map("canceled_at")
  rejectedAt           DateTime?    @map("rejected_at")
  rejectReason         String?      @map("reject_reason")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  seasonParticipant  SeasonParticipant   @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  asset              Asset               @relation(fields: [assetId], references: [id], onDelete: Restrict)
  assetPriceSnapshot AssetPriceSnapshot? @relation(fields: [assetPriceSnapshotId], references: [id], onDelete: Restrict)
  fxRateSnapshot     FxRateSnapshot?     @relation(fields: [fxRateSnapshotId], references: [id], onDelete: Restrict)

  @@unique([seasonParticipantId, idempotencyKey])
  @@index([seasonParticipantId, submittedAt])
  @@index([seasonParticipantId, status])
  @@index([assetId])
  @@index([assetPriceSnapshotId])
  @@index([fxRateSnapshotId])
  @@index([submittedAt])
  @@index([status])
  @@map("orders")
}

model CashWallet {
  id                  String       @id @default(uuid())
  seasonParticipantId String       @map("season_participant_id")
  currencyCode        CurrencyCode @map("currency_code")
  balanceAmount       Decimal      @map("balance_amount") @db.Decimal(24, 8)
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  seasonParticipant  SeasonParticipant   @relation(fields: [seasonParticipantId], references: [id], onDelete: Cascade)
  walletTransactions WalletTransaction[]

  @@unique([seasonParticipantId, currencyCode])
  @@index([seasonParticipantId])
  @@map("cash_wallets")
}

model WalletTransaction {
  id                  String                         @id @default(uuid())
  seasonParticipantId String                         @map("season_participant_id")
  walletId            String                         @map("wallet_id")
  currencyCode        CurrencyCode                   @map("currency_code")
  direction           WalletTransactionDirection
  txType              WalletTransactionType          @map("tx_type")
  referenceType       WalletTransactionReferenceType @map("reference_type")
  referenceId         String?                        @map("reference_id")
  amount              Decimal                        @db.Decimal(24, 8)
  balanceAfter        Decimal                        @map("balance_after") @db.Decimal(24, 8)
  occurredAt          DateTime                       @map("occurred_at")
  createdAt           DateTime                       @default(now()) @map("created_at")

  seasonParticipant SeasonParticipant @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  wallet            CashWallet        @relation(fields: [walletId], references: [id], onDelete: Restrict)

  @@index([seasonParticipantId, occurredAt])
  @@index([walletId, occurredAt])
  @@index([referenceType, referenceId])
  @@map("wallet_transactions")
}

model ExchangeTransaction {
  id                  String       @id @default(uuid())
  seasonParticipantId String       @map("season_participant_id")
  fxRateSnapshotId    String?      @map("fx_rate_snapshot_id")
  fromCurrency        CurrencyCode @map("from_currency")
  toCurrency          CurrencyCode @map("to_currency")
  sourceAmount        Decimal      @map("source_amount") @db.Decimal(24, 8)
  grossTargetAmount   Decimal      @map("gross_target_amount") @db.Decimal(24, 8)
  feeRate             Decimal      @map("fee_rate") @db.Decimal(10, 6)
  feeAmount           Decimal      @map("fee_amount") @db.Decimal(24, 8)
  feeCurrency         CurrencyCode @map("fee_currency")
  appliedRate         Decimal      @map("applied_rate") @db.Decimal(18, 8)
  netTargetAmount     Decimal      @map("net_target_amount") @db.Decimal(24, 8)
  executedAt          DateTime     @map("executed_at")
  createdAt           DateTime     @default(now()) @map("created_at")

  seasonParticipant SeasonParticipant  @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  fxRateSnapshot    FxRateSnapshot?    @relation(fields: [fxRateSnapshotId], references: [id], onDelete: Restrict)
  fxExecuteRequests FxExecuteRequest[]

  @@index([seasonParticipantId, executedAt])
  @@index([fxRateSnapshotId])
  @@index([fromCurrency, toCurrency, executedAt])
  @@map("exchange_transactions")
}

model FxRateSnapshot {
  id               String           @id @default(uuid())
  baseCurrency     CurrencyCode     @map("base_currency")
  quoteCurrency    CurrencyCode     @map("quote_currency")
  rate             Decimal          @db.Decimal(18, 8)
  sourceType       FxRateSourceType @map("source_type")
  sourceName       String?          @map("source_name")
  sourceTimestamp  DateTime?        @map("source_timestamp")
  effectiveAt      DateTime         @map("effective_at")
  capturedAt       DateTime         @map("captured_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  rawPayloadJson   Json?            @map("raw_payload_json")
  approvedByUserId String?          @map("approved_by_user_id")
  note             String?

  exchangeTransactions ExchangeTransaction[]
  orders               Order[]

  @@index([baseCurrency, quoteCurrency, effectiveAt])
  @@index([baseCurrency, quoteCurrency, capturedAt])
  @@index([sourceType, effectiveAt])
  @@map("fx_rate_snapshots")
}

model FxExecuteRequest {
  id                    String                 @id @default(uuid())
  userId                String                 @map("user_id")
  seasonParticipantId   String                 @map("season_participant_id")
  idempotencyKey        String                 @map("idempotency_key")
  requestHash           String                 @map("request_hash")
  fromCurrency          CurrencyCode           @map("from_currency")
  toCurrency            CurrencyCode           @map("to_currency")
  sourceAmount          Decimal                @map("source_amount") @db.Decimal(24, 8)
  status                FxExecuteRequestStatus
  exchangeTransactionId String?                @map("exchange_transaction_id")
  responsePayloadJson   Json?                  @map("response_payload_json")
  errorCode             String?                @map("error_code")
  errorMessage          String?                @map("error_message")
  requestedAt           DateTime               @map("requested_at")
  completedAt           DateTime?              @map("completed_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  user                User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  seasonParticipant   SeasonParticipant    @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)
  exchangeTransaction ExchangeTransaction? @relation(fields: [exchangeTransactionId], references: [id], onDelete: Restrict)

  @@unique([userId, idempotencyKey])
  @@index([seasonParticipantId, requestedAt])
  @@index([status, requestedAt])
  @@index([exchangeTransactionId])
  @@map("fx_execute_requests")
}

model EquitySnapshot {
  id                    String         @id @default(uuid())
  seasonParticipantId   String         @map("season_participant_id")
  totalAssetKrw         Decimal        @map("total_asset_krw") @db.Decimal(24, 8)
  returnRate            Decimal        @map("return_rate") @db.Decimal(12, 8)
  krwCash               Decimal        @map("krw_cash") @db.Decimal(24, 8)
  usdCashKrw            Decimal        @map("usd_cash_krw") @db.Decimal(24, 8)
  domesticStockValueKrw Decimal        @map("domestic_stock_value_krw") @db.Decimal(24, 8)
  usStockValueKrw       Decimal        @map("us_stock_value_krw") @db.Decimal(24, 8)
  cryptoValueKrw        Decimal        @map("crypto_value_krw") @db.Decimal(24, 8)
  snapshotReason        SnapshotReason @map("snapshot_reason")
  capturedAt            DateTime       @map("captured_at")
  createdAt             DateTime       @default(now()) @map("created_at")

  seasonParticipant SeasonParticipant @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)

  @@index([seasonParticipantId, capturedAt])
  @@index([snapshotReason, capturedAt])
  @@map("equity_snapshots")
}

model DailyPortfolioSnapshot {
  id                  String   @id @default(uuid())
  seasonParticipantId String   @map("season_participant_id")
  snapshotDate        DateTime @map("snapshot_date") @db.Date
  totalAssetKrw       Decimal  @map("total_asset_krw") @db.Decimal(24, 8)
  returnRate          Decimal  @map("return_rate") @db.Decimal(12, 8)
  krwCash             Decimal  @map("krw_cash") @db.Decimal(24, 8)
  usdCashKrw          Decimal  @map("usd_cash_krw") @db.Decimal(24, 8)
  assetValueKrw       Decimal  @map("asset_value_krw") @db.Decimal(24, 8)
  realizedPnlKrw      Decimal  @map("realized_pnl_krw") @db.Decimal(24, 8)
  unrealizedPnlKrw    Decimal  @map("unrealized_pnl_krw") @db.Decimal(24, 8)
  capturedAt          DateTime @map("captured_at")
  createdAt           DateTime @default(now()) @map("created_at")

  seasonParticipant SeasonParticipant @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)

  @@unique([seasonParticipantId, snapshotDate])
  @@index([snapshotDate])
  @@index([seasonParticipantId, capturedAt])
  @@map("daily_portfolio_snapshots")
}

model SeasonRanking {
  id                  String            @id @default(uuid())
  seasonId            String            @map("season_id")
  seasonParticipantId String            @map("season_participant_id")
  rankType            SeasonRankingType @default(daily) @map("rank_type")
  rank                Int
  totalAssetKrw       Decimal           @map("total_asset_krw") @db.Decimal(24, 8)
  returnRate          Decimal           @map("return_rate") @db.Decimal(12, 8)
  rankingDate         DateTime          @map("ranking_date") @db.Date
  capturedAt          DateTime          @map("captured_at")
  createdAt           DateTime          @default(now()) @map("created_at")

  season            Season            @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  seasonParticipant SeasonParticipant @relation(fields: [seasonParticipantId], references: [id], onDelete: Restrict)

  @@unique([seasonId, rankType, rankingDate, seasonParticipantId])
  @@unique([seasonId, rankType, rankingDate, rank])
  @@index([seasonId, rankType, rankingDate, rank])
  @@index([seasonParticipantId, rankingDate])
  @@map("season_rankings")
}

model BatchJobRun {
  id                 String         @id @default(uuid())
  jobName            String         @map("job_name")
  idempotencyKey     String         @map("idempotency_key")
  status             BatchJobStatus @default(pending)
  dryRun             Boolean        @default(false) @map("dry_run")
  startedAt          DateTime?      @map("started_at")
  finishedAt         DateTime?      @map("finished_at")
  requestedBy        String?        @map("requested_by")
  requestPayloadJson Json?          @map("request_payload_json")
  resultPayloadJson  Json?          @map("result_payload_json")
  errorCode          String?        @map("error_code")
  errorMessage       String?        @map("error_message")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  @@unique([jobName, idempotencyKey])
  @@index([jobName, status])
  @@index([jobName, createdAt])
  @@index([status, createdAt])
  @@map("batch_job_runs")
}
