# Optional. If omitted, the app uses local development defaults:
# - web: http://<current-web-host>:3000
# - Android emulator: http://10.0.2.2:3000
# - iOS simulator: http://localhost:3000
#
# For physical Android release/EAS builds, set this to your backend URL
# or your development machine's LAN IP.
# EXPO_PUBLIC_API_ORIGIN=http://192.168.0.10:3000
#
# Optional. If omitted, WebSocket origin is derived from EXPO_PUBLIC_API_ORIGIN.
# EXPO_PUBLIC_WS_BASE_URL=ws://192.168.0.10:3000

# Limit-buy order UI (phase 1). Default false/omitted: the market/limit
# toggle is hidden and only market orders can be created. Existing submitted
# limit orders remain visible and cancelable regardless of this flag.
# Requires the backend LIMIT_ORDER_ENABLED flag as well.
#
# Only an explicit `true` or `1` (trimmed, case-insensitive) enables it;
# `false`, `0`, an unrecognized value, and an unset variable all read as
# false. The client has no bootstrap step to fail, so it stays fail-closed
# here — the backend rejects a malformed LIMIT_ORDER_ENABLED at startup.
#
# EXPO_PUBLIC_* variables are inlined into the bundle at build time, so this
# must be set for the build/export command that produces the artifact —
# changing it later does not affect an already-built bundle. src/constants/
# env.ts must keep reading it with static dot notation for that inlining to
# happen at all (covered by src/constants/env.test.ts).
# EXPO_PUBLIC_LIMIT_ORDER_ENABLED=false
# Automatic execution messaging is server-authoritative through the additive
# quote/create executionPolicy object; there is intentionally no separate
# EXPO_PUBLIC auto-execution flag.
